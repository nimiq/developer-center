timeoutresolveproof","web-client/reference/interfaces/PlainHtlcTimeoutResolveProof",{"title":795,"path":796,"stem":797},"Interface: PlainMacroBlock","/web-client/reference/interfaces/plainmacroblock","web-client/reference/interfaces/PlainMacroBlock",{"title":799,"path":800,"stem":801},"Interface: PlainMicroBlock","/web-client/reference/interfaces/plainmicroblock","web-client/reference/interfaces/PlainMicroBlock",{"title":803,"path":804,"stem":805},"Interface: PlainPeerInfo","/web-client/reference/interfaces/plainpeerinfo","web-client/reference/interfaces/PlainPeerInfo",{"title":807,"path":808,"stem":809},"Interface: PlainRawData","/web-client/reference/interfaces/plainrawdata","web-client/reference/interfaces/PlainRawData",{"title":811,"path":812,"stem":813},"Interface: PlainRawProof","/web-client/reference/interfaces/plainrawproof","web-client/reference/interfaces/PlainRawProof",{"title":815,"path":816,"stem":817},"Interface: PlainRetireStakeData","/web-client/reference/interfaces/plainretirestakedata","web-client/reference/interfaces/PlainRetireStakeData",{"title":819,"path":820,"stem":821},"Interface: PlainSetActiveStakeData","/web-client/reference/interfaces/plainsetactivestakedata","web-client/reference/interfaces/PlainSetActiveStakeData",{"title":823,"path":824,"stem":825},"Interface: PlainStaker","/web-client/reference/interfaces/plainstaker","web-client/reference/interfaces/PlainStaker",{"title":827,"path":828,"stem":829},"Interface: PlainStakingContract","/web-client/reference/interfaces/plainstakingcontract","web-client/reference/interfaces/PlainStakingContract",{"title":831,"path":832,"stem":833},"Interface: PlainStandardProof","/web-client/reference/interfaces/plainstandardproof","web-client/reference/interfaces/PlainStandardProof",{"title":835,"path":836,"stem":837},"Interface: PlainTransaction","/web-client/reference/interfaces/plaintransaction","web-client/reference/interfaces/PlainTransaction",{"title":839,"path":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":423,"body":921,"description":1206,"extension":1207,"icon":1208,"layout":1209,"meta":1210,"navigation":1212,"path":424,"seo":1213,"stem":425,"__hash__":1214},"docs/protocol/zkp/prover-node.md",{"type":922,"value":923,"toc":1196},"minimark",[924,928,946,949,952,957,967,970,982,986,989,992,996,999,1002,1005,1009,1015,1018,1049,1064,1070,1073,1076,1080,1083,1086,1113,1134,1139,1159,1163,1180,1185,1192],[925,926,927],"p",{},"The blockchain uses zero-knowledge proofs to:",[929,930,931,940,943],"ul",{},[932,933,934,935,939],"li",{},"Facilitate light nodes and full nodes to ",[936,937,938],"a",{"href":352},"sync"," with the blockchain",[932,941,942],{},"Enable nodes to reconnect with the blockchain faster",[932,944,945],{},"Secure the network",[925,947,948],{},"Zero-knowledge proofs prove the chain’s integrity from the genesis block to the latest election macro block in a small proof, which makes it easy for the node receiving it to verify. The proof size remains the same regardless of whether the node requests a proof from the genesis block or the latest macro block.",[925,950,951],{},"From the verifier side, receiving and verifying a zero-knowledge proof is a fast process, but generating such proof takes significant computational power and space from the prover node side. Generating these proofs takes time but verifying them is a quick process.",[953,954,956],"h2",{"id":955},"prover-component","Prover Component",[925,958,959,960,966],{},"Each node in the network has a particular component within its configuration - the ",[936,961,965],{"href":962,"rel":963},"https://github.com/nimiq/core-rs-albatross/blob/ac50167e912b8e36223675495eed1ecd9e226b1c/zkp-component/src/zkp_component.rs",[964],"nofollow","zkp component",". The component allows nodes to perform multiple tasks such as proof storage, proof of network communication, thus requests and gossip, and optionally proof generation.",[925,968,969],{},"But not all nodes need or want to be prover nodes. Being a validator takes considerable computational power, and so does being a prover node. But oppositely to validators, there is no incentive to generate these proofs aside from making the network a more secure and reliable environment.",[925,971,972,973,977,978,981],{},"The prover node component is within the node's configuration, but the feature is disabled by default. Nodes must activate the feature ",[974,975,976],"code",{},"is_prover_active: bool"," to have the ability to generate a proof. Whenever a node wants to generate a proof, it has to set this feature to ",[974,979,980],{},"true",".",[953,983,985],{"id":984},"database","Database",[925,987,988],{},"The zkp component also holds a database that allows nodes to store zero-knowledge proofs, preventing losing access to them in the future. The database can be enabled or disabled according to the node choice. Activating the database will allow the node to reconnect from the last zkp in its database.",[925,990,991],{},"If a synced node loses connection, it can reconnect by providing the block number of the last zero-knowledge proof stored in its database. But if it doesn't have its database active and loses connection when reconnecting, it will have to resync from the start of the chain, thus from the genesis block, as it can't fetch old proofs.",[953,993,995],{"id":994},"implementation-of-a-zero-knowledge-proof","Implementation of a Zero-knowledge Proof",[925,997,998],{},"Zero-knowledge proofs are generated based on three conditions - correctness, soundness, and zero-knowledge. Therefore, by respecting these conditions, the proof attests to the validity of the block production from the genesis block to the respective election block.",[925,1000,1001],{},"There is a possible delay in the zero-knowledge proof generation, where a new election block comes in while the prover node is still generating the proof for the previous election block. Considering this delay, prover nodes provide the latest proof available.",[925,1003,1004],{},"When nodes first sync to the chain, they start at block 0 or genesis block, which is an election block. The genesis block comes with a null proof as it doesn't contain any element to enable zero-knowledge proof generation. Prover nodes generate these proofs at every election block after the genesis block.",[953,1006,1008],{"id":1007},"generating-a-zero-knowledge-proof","Generating a Zero-knowledge Proof",[925,1010,1011,1012,981],{},"The process of generating such proofs is resource-intensive and time-consuming, as it is, for instance, for a history node or a validator node. The prover node generates the proof, stores it in its memory, and propagates it among the network. Note that a zkp can only be generated if it has the feature ",[974,1013,1014],{},"is_prover_node: true",[925,1016,1017],{},"The proof consists of the last election block number and the proof itself, as follows:",[1019,1020,1025],"pre",{"className":1021,"code":1022,"language":1023,"meta":1024,"style":1024},"language-rust shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","pub struct ZKProof {\n    pub block_number: u32,\n    pub proof: Option\u003CProof\u003CMNT6_753>>,\n}\n","rust","",[974,1026,1027,1034,1039,1044],{"__ignoreMap":1024},[1028,1029,1031],"span",{"class":1030,"line":12},"line",[1028,1032,1033],{},"pub struct ZKProof {\n",[1028,1035,1036],{"class":1030,"line":27},[1028,1037,1038],{},"    pub block_number: u32,\n",[1028,1040,1041],{"class":1030,"line":22},[1028,1042,1043],{},"    pub proof: Option\u003CProof\u003CMNT6_753>>,\n",[1028,1045,1046],{"class":1030,"line":17},[1028,1047,1048],{},"}\n",[929,1050,1051,1058],{},[932,1052,1053,1054,1057],{},"The ",[974,1055,1056],{},"block_number"," consists of the most recent election block. This number must be greater than the node's number in the request.",[932,1059,1053,1060,1063],{},[974,1061,1062],{},"proof"," consists of the zero-knowledge proof generated using a construction based on the MNT4-753 and MNT6-753 elliptic curves.",[925,1065,1066,1067,1069],{},"In case of a first connection with the network, the node provides the ",[974,1068,1056],{}," 0 as the most recent proof, despite the genesis block having no proof attached to it.",[925,1071,1072],{},"In the case of a node that was synced and had a zero-knowledge proof for election block 43200 in its database, the resync method would differ. If it gets disconnected by chance, when reconnecting again, this node can try to resync with the chain by requesting a zkp more recent than block 43200. However, if this same node hadn't activated the database feature, it would be unable to resync from the same point and have to sync from the genesis block.",[925,1074,1075],{},"Note that both cases depend on the type of node syncing, as sync with a zero-knowledge proof only applies to light nodes and full nodes.",[953,1077,1079],{"id":1078},"requesting-a-zero-knowledge-proof","Requesting a Zero-knowledge Proof",[925,1081,1082],{},"The requesting node, rather than downloading and verifying all election macro blocks since the genesis block, can verify the chain's validity with a zero-knowledge proof upon request. Once a node receives a proof, it first verifies it and then stores it using the zkp component and enabling the database feature.",[925,1084,1085],{},"Whether a node is syncing for the first time or reconnecting to the network, it must request proof to be up-to-date. The request looks as follows:",[1087,1088,1089],"code-group",{},[1019,1090,1092],{"className":1021,"code":1091,"language":1023,"meta":1024,"style":1024},"pub struct RequestZKP {\n    pub(crate) block_number: u32,\n    pub(crate) request_election_block: bool,\n}\n",[974,1093,1094,1099,1104,1109],{"__ignoreMap":1024},[1028,1095,1096],{"class":1030,"line":12},[1028,1097,1098],{},"pub struct RequestZKP {\n",[1028,1100,1101],{"class":1030,"line":27},[1028,1102,1103],{},"    pub(crate) block_number: u32,\n",[1028,1105,1106],{"class":1030,"line":22},[1028,1107,1108],{},"    pub(crate) request_election_block: bool,\n",[1028,1110,1111],{"class":1030,"line":17},[1028,1112,1048],{},[929,1114,1115,1120],{},[932,1116,1053,1117,1119],{},[974,1118,1056],{}," expected is the last election block the node knows of.",[932,1121,1122,1123,1126,1127,1129,1130,1133],{},"If the ",[974,1124,1125],{},"request_election_block"," is ",[974,1128,980],{},", the node expects to receive the complete election block; if set to ",[974,1131,1132],{},"false",", the node expects to receive the most recent election block number and the proof.",[1135,1136,1138],"h3",{"id":1137},"syncing-to-the-blockchain","Syncing to the Blockchain",[1140,1141,1142,1145,1150,1153,1156],"ol",{},[932,1143,1144],{},"node connects to the network",[932,1146,1147,1148],{},"node requests a zkp by providing the genesis block as ",[974,1149,1056],{},[932,1151,1152],{},"node verifies the zkp",[932,1154,1155],{},"node stores the zkp",[932,1157,1158],{},"node continues the syncing process",[1135,1160,1162],{"id":1161},"resyncing-to-the-blockchain","Resyncing to the Blockchain",[1140,1164,1165,1168,1174,1176,1178],{},[932,1166,1167],{},"node reconnects to the network",[932,1169,1170,1171,1173],{},"node requests a zkp by providing the ",[974,1172,1056],{}," of the latest zkp in its database",[932,1175,1152],{},[932,1177,1155],{},[932,1179,1158],{},[1181,1182,1184],"h4",{"id":1183},"see-also","See Also",[925,1186,1187,1188,981],{},"To complete the prover node setup, you'll need the proving keys. For detailed instructions on how to download and configure the proving keys, please refer to the ",[936,1189,1191],{"href":1190},"../../nodes/prover-node-guide","prover node setup guide",[1193,1194,1195],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":1024,"searchDepth":27,"depth":27,"links":1197},[1198,1199,1200,1201,1202],{"id":955,"depth":27,"text":956},{"id":984,"depth":27,"text":985},{"id":994,"depth":27,"text":995},{"id":1007,"depth":27,"text":1008},{"id":1078,"depth":27,"text":1079,"children":1203},[1204,1205],{"id":1137,"depth":22,"text":1138},{"id":1161,"depth":22,"text":1162},"A prover node is a particular type of node that generates zero-knowledge proofs (zkp). A zero-knowledge proof is a method of proving a statement between two parties - a prover and a verifier. Read this post for a detailed description of zero-knowledge proofs.","md","i-tabler:server",null,{"matter":1211},{"title":423,"description":1206},{"title":423,"order":27},{"title":423,"description":1206},"p8LDFmpWgqJ4C0GctYJxLydANiIhs6MMYQ-2lPcYHjI",[1216,1218],{"title":419,"path":420,"stem":421,"description":1217,"order":12,"children":-1},"Nimiq supports several types of users and syncing mechanisms. Light and full nodes can synchronize to the network by requesting a proof of the current state of the blockchain. The blockchain implements zero-knowledge proofs capable of proving most of the chain in a small proof.",{"title":10,"path":428,"stem":432,"description":1219,"order":12,"children":-1},"Connect your backend services to the Nimiq blockchain with full access to blockchain data and operations through standard JSON-RPC and RESTful endpoints.",1773431219240]
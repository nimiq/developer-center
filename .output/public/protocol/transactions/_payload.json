reference/interfaces/InitOutput",{"title":751,"path":752,"stem":753},"Interface: PlainAddStakeData","/web-client/reference/interfaces/plainaddstakedata","web-client/reference/interfaces/PlainAddStakeData",{"title":755,"path":756,"stem":757},"Interface: PlainBasicAccount","/web-client/reference/interfaces/plainbasicaccount","web-client/reference/interfaces/PlainBasicAccount",{"title":759,"path":760,"stem":761},"Interface: PlainBlockCommonFields","/web-client/reference/interfaces/plainblockcommonfields","web-client/reference/interfaces/PlainBlockCommonFields",{"title":763,"path":764,"stem":765},"Interface: PlainClientConfiguration","/web-client/reference/interfaces/plainclientconfiguration","web-client/reference/interfaces/PlainClientConfiguration",{"title":767,"path":768,"stem":769},"Interface: PlainCreateStakerData","/web-client/reference/interfaces/plaincreatestakerdata","web-client/reference/interfaces/PlainCreateStakerData",{"title":771,"path":772,"stem":773},"Interface: PlainCreateValidatorData","/web-client/reference/interfaces/plaincreatevalidatordata","web-client/reference/interfaces/PlainCreateValidatorData",{"title":775,"path":776,"stem":777},"Interface: PlainHtlcContract","/web-client/reference/interfaces/plainhtlccontract","web-client/reference/interfaces/PlainHtlcContract",{"title":779,"path":780,"stem":781},"Interface: PlainHtlcData","/web-client/reference/interfaces/plainhtlcdata","web-client/reference/interfaces/PlainHtlcData",{"title":783,"path":784,"stem":785},"Interface: PlainHtlcEarlyResolveProof","/web-client/reference/interfaces/plainhtlcearlyresolveproof","web-client/reference/interfaces/PlainHtlcEarlyResolveProof",{"title":787,"path":788,"stem":789},"Interface: PlainHtlcRegularTransferProof","/web-client/reference/interfaces/plainhtlcregulartransferproof","web-client/reference/interfaces/PlainHtlcRegularTransferProof",{"title":791,"path":792,"stem":793},"Interface: PlainHtlcTimeoutResolveProof","/web-client/reference/interfaces/plainhtlctimeoutresolveproof","web-client/reference/interfaces/PlainHtlcTimeoutResolveProof",{"title":795,"path":796,"stem":797},"Interface: PlainMacroBlock","/web-client/reference/interfaces/plainmacroblock","web-client/reference/interfaces/PlainMacroBlock",{"title":799,"path":800,"stem":801},"Interface: PlainMicroBlock","/web-client/reference/interfaces/plainmicroblock","web-client/reference/interfaces/PlainMicroBlock",{"title":803,"path":804,"stem":805},"Interface: PlainPeerInfo","/web-client/reference/interfaces/plainpeerinfo","web-client/reference/interfaces/PlainPeerInfo",{"title":807,"path":808,"stem":809},"Interface: PlainRawData","/web-client/reference/interfaces/plainrawdata","web-client/reference/interfaces/PlainRawData",{"title":811,"path":812,"stem":813},"Interface: PlainRawProof","/web-client/reference/interfaces/plainrawproof","web-client/reference/interfaces/PlainRawProof",{"title":815,"path":816,"stem":817},"Interface: PlainRetireStakeData","/web-client/reference/interfaces/plainretirestakedata","web-client/reference/interfaces/PlainRetireStakeData",{"title":819,"path":820,"stem":821},"Interface: PlainSetActiveStakeData","/web-client/reference/interfaces/plainsetactivestakedata","web-client/reference/interfaces/PlainSetActiveStakeData",{"title":823,"path":824,"stem":825},"Interface: PlainStaker","/web-client/reference/interfaces/plainstaker","web-client/reference/interfaces/PlainStaker",{"title":827,"path":828,"stem":829},"Interface: PlainStakingContract","/web-client/reference/interfaces/plainstakingcontract","web-client/reference/interfaces/PlainStakingContract",{"title":831,"path":832,"stem":833},"Interface: PlainStandardProof","/web-client/reference/interfaces/plainstandardproof","web-client/reference/interfaces/PlainStandardProof",{"title":835,"path":836,"stem":837},"Interface: PlainTransaction","/web-client/reference/interfaces/plaintransaction","web-client/reference/interfaces/PlainTransaction",{"title":839,"path":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":98,"body":921,"description":1568,"extension":1569,"icon":1570,"layout":1571,"meta":1572,"navigation":1574,"path":384,"seo":1575,"stem":385,"__hash__":1576},"docs/protocol/transactions.md",{"type":922,"value":923,"toc":1555},"minimark",[924,929,933,961,969,973,976,990,996,1000,1213,1218,1263,1273,1277,1280,1301,1305,1308,1352,1356,1359,1420,1423,1426,1429,1443,1448,1451,1475,1479,1485,1489,1495,1500,1520,1523],[925,926,928],"h2",{"id":927},"types-of-accounts","Types of Accounts",[930,931,932],"p",{},"Nimiq supports four types of accounts, each designed for different purposes:",[934,935,936,944,950,956],"ul",{},[937,938,939,943],"li",{},[940,941,942],"strong",{},"Basic Account",": The most commonly used account for standard transactions between individuals or entities",[937,945,946,949],{},[940,947,948],{},"Hashed Time-Locked Contract (HTLC)",": Handles conditional transfers, such as atomic swaps, based on cryptographic conditions and time constraints",[937,951,952,955],{},[940,953,954],{},"Vesting Contract",": Manages funds released gradually over time, often used to lock funds with a defined release schedule",[937,957,958,960],{},[940,959,403],{},": Enables validators to lock their NIM, participate in network consensus, and earn rewards",[930,962,963,964,968],{},"Each account type processes transactions differently to meet its specific use case. For more details, refer to the ",[965,966,967],"a",{"href":282},"accounts"," documentation.",[925,970,972],{"id":971},"transaction-prioritization-and-mempool","Transaction Prioritization and Mempool",[930,974,975],{},"Transactions are first placed in the mempool, waiting for validation. Nimiq has two mempools:",[934,977,978,984],{},[937,979,980,983],{},[940,981,982],{},"Regular Mempool",": For basic, HTLC, and vesting transactions",[937,985,986,989],{},[940,987,988],{},"Control Mempool",": For staking transactions, which are prioritized",[930,991,992,993,968],{},"Once selected by a validator, transactions are validated and included in a block if they meet the protocol’s requirements. For more details on how the mempool operates, refer to the ",[965,994,995],{"href":377},"mempool",[925,997,999],{"id":998},"transaction-structure","Transaction Structure",[1001,1002,1003,1025],"table",{},[1004,1005,1006],"thead",{},[1007,1008,1009,1015,1020],"tr",{},[1010,1011,1012],"th",{},[940,1013,1014],{},"Field",[1010,1016,1017],{},[940,1018,1019],{},"Data Type",[1010,1021,1022],{},[940,1023,1024],{},"Description",[1026,1027,1028,1045,1065,1083,1097,1111,1125,1140,1154,1169,1184,1199],"tbody",{},[1007,1029,1030,1037,1042],{},[1031,1032,1033],"td",{},[1034,1035,1036],"code",{},"sender",[1031,1038,1039],{},[1034,1040,1041],{},"Address",[1031,1043,1044],{},"The sender’s address",[1007,1046,1047,1052,1057],{},[1031,1048,1049],{},[1034,1050,1051],{},"sender_type",[1031,1053,1054],{},[1034,1055,1056],{},"AccountType",[1031,1058,1059,1060,1064],{},"Specifies the ",[965,1061,1063],{"href":1062},"#types-of-accounts","type"," of the sender account",[1007,1066,1067,1072,1077],{},[1031,1068,1069],{},[1034,1070,1071],{},"sender_data",[1031,1073,1074],{},[1034,1075,1076],{},"Vec\u003Cu8>",[1031,1078,1079,1080],{},"Additional data specific to the sender account’s type, primarily used for extra info in transactions from the ",[965,1081,1082],{"href":404},"staking contract",[1007,1084,1085,1090,1094],{},[1031,1086,1087],{},[1034,1088,1089],{},"recipient",[1031,1091,1092],{},[1034,1093,1041],{},[1031,1095,1096],{},"The recipient’s address",[1007,1098,1099,1104,1108],{},[1031,1100,1101],{},[1034,1102,1103],{},"recipient_type",[1031,1105,1106],{},[1034,1107,1056],{},[1031,1109,1110],{},"Specifies the type of the recipient account",[1007,1112,1113,1118,1122],{},[1031,1114,1115],{},[1034,1116,1117],{},"recipient_data",[1031,1119,1120],{},[1034,1121,1076],{},[1031,1123,1124],{},"Additional data specific to the recipient account. Used in transactions involving contracts such as staking, HTLCs, and vesting contracts.",[1007,1126,1127,1132,1137],{},[1031,1128,1129],{},[1034,1130,1131],{},"value",[1031,1133,1134],{},[1034,1135,1136],{},"Coin",[1031,1138,1139],{},"The amount of NIM to transfer. This field can be zero for transactions that do not transfer value but interact with the staking contract",[1007,1141,1142,1147,1151],{},[1031,1143,1144],{},[1034,1145,1146],{},"fee",[1031,1148,1149],{},[1034,1150,1136],{},[1031,1152,1153],{},"The fee paid by the sender for the transaction. Validators earn this fee as part of the block rewards for including the transaction in the blockchain as an incentive",[1007,1155,1156,1161,1166],{},[1031,1157,1158],{},[1034,1159,1160],{},"validity_start_height",[1031,1162,1163],{},[1034,1164,1165],{},"u32",[1031,1167,1168],{},"The block height from which the transaction becomes valid. A transaction can be submitted before this height, but will only be eligible for inclusion once the blockchain reaches this height. If not included in a block within the window of 120 blocks after, the transaction will expire",[1007,1170,1171,1176,1181],{},[1031,1172,1173],{},[1034,1174,1175],{},"network_id",[1031,1177,1178],{},[1034,1179,1180],{},"NetworkId",[1031,1182,1183],{},"Specifies the network (Mainnet, Testnet) on which the transaction is valid to ensure the transaction is only processed on the correct network",[1007,1185,1186,1191,1196],{},[1031,1187,1188],{},[1034,1189,1190],{},"flags",[1031,1192,1193],{},[1034,1194,1195],{},"TransactionFlags",[1031,1197,1198],{},"Flags that indicate special transaction types, such as contract creation or signaling",[1007,1200,1201,1206,1210],{},[1031,1202,1203],{},[1034,1204,1205],{},"proof",[1031,1207,1208],{},[1034,1209,1076],{},[1031,1211,1212],{},"A cryptographic proof, generated by signing the transaction data with the sender’s private key, which authenticates the sender",[930,1214,1215],{},[940,1216,1217],{},"Additional Considerations",[934,1219,1220,1226,1240,1249],{},[937,1221,1222,1225],{},[940,1223,1224],{},"Variations in Transaction Structure",": Different account types (basic, HTLC, vesting, staking) may have variations in their transaction structure. These variations ensure that each account type processes transactions according to its specific purpose and function within the protocol",[937,1227,1228,1231,1232,1235,1236,1239],{},[940,1229,1230],{},"Incoming and Outgoing Transactions",": The network distinguishes between incoming and outgoing transactions. ",[940,1233,1234],{},"Incoming transactions"," are related to operations within an account, such as adding stake or creating an account. ",[940,1237,1238],{},"Outgoing transactions"," involve external account operations that affect the network state, such as deleting a validator or removing stake",[937,1241,1242,1245,1246,1248],{},[940,1243,1244],{},"Zero-Value Transactions",": Staking transactions can have a zero ",[1034,1247,1131],{}," field for contract interaction without fund transfer",[937,1250,1251,1254,1255,1258,1259,1262],{},[940,1252,1253],{},"Serialization and Deserialization",": Transactions are ",[940,1256,1257],{},"serialized"," to reduce size for transmission and ",[940,1260,1261],{},"deserialized"," by nodes for validation and processing across the network",[930,1264,1265,1266,1272],{},"For a deeper dive into the transactions and serialization specifics, refer to the document ",[965,1267,1271],{"href":1268,"rel":1269},"https://gist.github.com/sisou/33ece69190cf38f884b1781ad9d5a106",[1270],"nofollow","Albatross Transaction Serialization",".",[925,1274,1276],{"id":1275},"transaction-flow-and-potential-issues","Transaction Flow and Potential Issues",[930,1278,1279],{},"Transactions go through multiple stages of verification before being added to a block, and there are potential issues that might arise at each stage:",[1281,1282,1283,1289,1295],"ol",{},[937,1284,1285,1288],{},[940,1286,1287],{},"Transaction Builder Errors",": These occur when creating a transaction and required fields (such as the sender, recipient, or value) are missing or invalid",[937,1290,1291,1294],{},[940,1292,1293],{},"Transaction Errors",": These errors happen when the transaction is submitted to the network, where the transaction fails checks like invalid proof, wrong network, or serialization errors",[937,1296,1297,1300],{},[940,1298,1299],{},"Failed Transactions",": Even after the previous steps have been successfully verified with no errors, a transaction can fail if the sender lacks sufficient funds to cover the transaction value or the fees",[1302,1303,1287],"h3",{"id":1304},"transaction-builder-errors",[930,1306,1307],{},"Deals with missing or invalid fields when creating transactions. If any of the following errors occur, the transaction will not even be sent:",[934,1309,1310,1316,1322,1328,1334,1340,1346],{},[937,1311,1312,1315],{},[940,1313,1314],{},"No Sender",": The sender address is missing from the transaction",[937,1317,1318,1321],{},[940,1319,1320],{},"No Recipient",": The recipient address is missing. A valid recipient must be provided",[937,1323,1324,1327],{},[940,1325,1326],{},"No Value",": The transaction value (amount to be transferred) is missing",[937,1329,1330,1333],{},[940,1331,1332],{},"No Validity Start Height",": The transaction’s validity start height, which defines from when the transaction becomes valid, is not set",[937,1335,1336,1339],{},[940,1337,1338],{},"No Network ID",": The transaction’s network ID is missing. The ID identifies which network the transaction is intended, whether Testnet or Mainnet",[937,1341,1342,1345],{},[940,1343,1344],{},"Invalid Sender",": The sender is not valid for the recipient",[937,1347,1348,1351],{},[940,1349,1350],{},"Invalid Value",": For signaling transactions, the value must be zero, whereas other transactions require a non-zero value. This error is triggered when the value does not match the requirements for the specific transaction type",[1302,1353,1355],{"id":1354},"transaction-error","Transaction Error",[930,1357,1358],{},"Deals with transaction execution issues when it is submitted to the network:",[934,1360,1361,1367,1373,1378,1384,1390,1396,1402,1408,1414],{},[937,1362,1363,1366],{},[940,1364,1365],{},"Foreign Network",": The transaction is intended for a network other than the one it was submitted to (a transaction for the Testnet being submitted to the Mainnet)",[937,1368,1369,1372],{},[940,1370,1371],{},"Zero Value",": The transaction’s value is set to zero when it’s not allowed. Transactions that transfer funds must have a non-zero value unless they are specific contract interactions that permit zero-value transactions",[937,1374,1375,1377],{},[940,1376,1350],{},": The value of the transaction is not valid for the specific operation being attempted (incorrect value for contract-related transactions)",[937,1379,1380,1383],{},[940,1381,1382],{},"Overflow",": The transaction causes an overflow in calculations, due to large values that cannot be processed",[937,1385,1386,1389],{},[940,1387,1388],{},"Sender Equals Recipient",": The sender and recipient of the transaction are the same which is not allowed",[937,1391,1392,1395],{},[940,1393,1394],{},"Invalid For Sender",": The transaction is not valid for the sender’s account type or current state",[937,1397,1398,1401],{},[940,1399,1400],{},"Invalid Proof",": The cryptographic proof for the transaction is incorrect, meaning the transaction was not correctly signed by the sender",[937,1403,1404,1407],{},[940,1405,1406],{},"Invalid For Recipient",": The transaction is not valid for the recipient’s account type or current state",[937,1409,1410,1413],{},[940,1411,1412],{},"Invalid Data",": The transaction contains invalid data, which could refer to incorrect parameters or malformed data fields",[937,1415,1416,1419],{},[940,1417,1418],{},"Invalid Serialization",": There is an issue with the serialization of the transaction, typically occurring during the encoding or decoding process",[1302,1421,1299],{"id":1422},"failed-transactions",[930,1424,1425],{},"The final verification of a transaction occurs before it enters the mempool. Even if it passes earlier stages, it can fail if the sender lacks sufficient funds. Validators ensure the sender can cover the transaction fees before adding it to the mempool. If the sender does not even have enough for the fees, the transaction is deemed invalid and not processed.",[930,1427,1428],{},"Including a transaction in a block may succeed or fail:",[934,1430,1431,1437],{},[937,1432,1433,1436],{},[940,1434,1435],{},"Successful",": The sender has enough funds to cover both the transaction value and fees, and the user's balance is updated",[937,1438,1439,1442],{},[940,1440,1441],{},"Failed",": The sender has insufficient funds to pay out the transaction value but transaction fees can be deducted",[930,1444,1445],{},[940,1446,1447],{},"Example Scenario",[930,1449,1450],{},"Consider a scenario where Alice has 100 NIM in her balance. She sends 3 transactions:",[934,1452,1453,1459,1465],{},[937,1454,1455,1458],{},[940,1456,1457],{},"Transaction 1",": Alice sends 80 NIM to Bob. Since she has sufficient funds (80 NIM + fees), this transaction succeeds, and both the value and fees are deducted from her account",[937,1460,1461,1464],{},[940,1462,1463],{},"Transaction 2",": Alice attempts to send 50 NIM to Charlie immediately after. Since her remaining balance is insufficient to cover both the value and fees, this transaction fails, but the transaction fees are still deducted",[937,1466,1467,1470,1471,1474],{},[940,1468,1469],{},"Transaction 3",": Alice tries to send another transaction but does not have enough NIM to cover the fee. In this case, the transaction is deemed ",[940,1472,1473],{},"invalid"," and is not processed by the network. Neither the value nor the fees are deducted",[925,1476,1478],{"id":1477},"transaction-finality","Transaction Finality",[930,1480,1481,1482,968],{},"Finality is periodically reinforced through the Tendermint protocol, which ensures that blocks and the transactions within them cannot be reversed once they are finalized by a macro block. For more details on how finality is achieved through the block structure, please refer to the ",[965,1483,1484],{"href":291},"block format",[925,1486,1488],{"id":1487},"inherents","Inherents",[930,1490,1491,1492,1494],{},"In addition to user-initiated transactions, Nimiq also processes ",[940,1493,1487],{},"—system-generated operations that modify the blockchain’s state without requiring a transaction from a user. These are used for tasks like distributing rewards and enforcing punishments, ensuring network stability.",[930,1496,1497],{},[940,1498,1499],{},"Key Characteristics of Inherents:",[934,1501,1502,1508,1514],{},[937,1503,1504,1507],{},[940,1505,1506],{},"No Account Interaction",": Inherents don’t originate from user accounts or affect balances",[937,1509,1510,1513],{},[940,1511,1512],{},"System-Driven",": These operations are generated by the protocol itself based on network rules and conditions",[937,1515,1516,1519],{},[940,1517,1518],{},"No Signature Requirement",": Inherents don’t require digital signatures for validation.",[930,1521,1522],{},"There are 5 types of inherents in the Nimiq protocol:",[934,1524,1525,1531,1537,1543,1549],{},[937,1526,1527,1530],{},[940,1528,1529],{},"Reward",": Automatically issued to validators who successfully fulfill their assigned slots without misbehavior",[937,1532,1533,1536],{},[940,1534,1535],{},"Penalty",": Applied to validators who delay block production. The penalty removes their reward for the slot, and the validator can be deactivated",[937,1538,1539,1542],{},[940,1540,1541],{},"Jail",": Enforced when validators are involved in severe misbehavior, such as double voting or creating forks. In this case, all of their slots are punished, and the validator is jailed, preventing further participation in the network for 8 epochs",[937,1544,1545,1548],{},[940,1546,1547],{},"Finalize Batch",": Triggered at the end of each batch of micro blocks, marking its completion",[937,1550,1551,1554],{},[940,1552,1553],{},"Finalize Epoch",": Occurs at the end of an epoch, marking a significant period in the blockchain's state updates. This ensures that all transactions and state changes for the epoch are finalized and the validator list is updated",{"title":1556,"searchDepth":27,"depth":27,"links":1557},"",[1558,1559,1560,1561,1566,1567],{"id":927,"depth":27,"text":928},{"id":971,"depth":27,"text":972},{"id":998,"depth":27,"text":999},{"id":1275,"depth":27,"text":1276,"children":1562},[1563,1564,1565],{"id":1304,"depth":22,"text":1287},{"id":1354,"depth":22,"text":1355},{"id":1422,"depth":22,"text":1299},{"id":1477,"depth":27,"text":1478},{"id":1487,"depth":27,"text":1488},"Transactions modify the state of the Nimiq blockchain according to protocol rules and enable value transfers and contract interactions. These transactions are stored in the micro block's body. This document provides a technical overview of transaction structure, common transaction issues, transaction finality, and system operations known as inherents in the Nimiq blockchain.","md","i-tabler:receipt",null,{"matter":1573},{"title":98,"description":1568},{"title":98,"order":17},{"title":98,"description":1568},"57_uR-HECkqXNdkPIhTQqO9uFHjlFSnwaxwrvQ11dSg",[1578,1580],{"title":380,"path":381,"stem":382,"description":1579,"order":27,"children":-1},"In the context of blockchain, ensuring data security is paramount. Our blockchain uses a tree-like structure known as Merkle Trees to store accounts and transactions. This approach guarantees that every piece of data is encoded within these trees, ultimately resulting in a single value called the \"root.\" This root value represents the entire dataset and acts as a commitment to the data being stored in the blocks.",{"title":391,"path":392,"stem":393,"description":1581,"order":228,"children":-1},"Skip blocks are a special type of micro block in the consensus protocol. When a validator fails to produce a block within the expected timeframe, the remaining elected validators can collectively agree to add a skip block instead of the missing micro block. This prevents delays and ensures the blockchain progresses smoothly. Once a supermajority of elected validators agrees to add the skip block, the chain resumes its regular progression.",1773431218845]
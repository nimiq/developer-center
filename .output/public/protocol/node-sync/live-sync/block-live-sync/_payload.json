eb-client/reference/interfaces/plainhtlctimeoutresolveproof","web-client/reference/interfaces/PlainHtlcTimeoutResolveProof",{"title":795,"path":796,"stem":797},"Interface: PlainMacroBlock","/web-client/reference/interfaces/plainmacroblock","web-client/reference/interfaces/PlainMacroBlock",{"title":799,"path":800,"stem":801},"Interface: PlainMicroBlock","/web-client/reference/interfaces/plainmicroblock","web-client/reference/interfaces/PlainMicroBlock",{"title":803,"path":804,"stem":805},"Interface: PlainPeerInfo","/web-client/reference/interfaces/plainpeerinfo","web-client/reference/interfaces/PlainPeerInfo",{"title":807,"path":808,"stem":809},"Interface: PlainRawData","/web-client/reference/interfaces/plainrawdata","web-client/reference/interfaces/PlainRawData",{"title":811,"path":812,"stem":813},"Interface: PlainRawProof","/web-client/reference/interfaces/plainrawproof","web-client/reference/interfaces/PlainRawProof",{"title":815,"path":816,"stem":817},"Interface: PlainRetireStakeData","/web-client/reference/interfaces/plainretirestakedata","web-client/reference/interfaces/PlainRetireStakeData",{"title":819,"path":820,"stem":821},"Interface: PlainSetActiveStakeData","/web-client/reference/interfaces/plainsetactivestakedata","web-client/reference/interfaces/PlainSetActiveStakeData",{"title":823,"path":824,"stem":825},"Interface: PlainStaker","/web-client/reference/interfaces/plainstaker","web-client/reference/interfaces/PlainStaker",{"title":827,"path":828,"stem":829},"Interface: PlainStakingContract","/web-client/reference/interfaces/plainstakingcontract","web-client/reference/interfaces/PlainStakingContract",{"title":831,"path":832,"stem":833},"Interface: PlainStandardProof","/web-client/reference/interfaces/plainstandardproof","web-client/reference/interfaces/PlainStandardProof",{"title":835,"path":836,"stem":837},"Interface: PlainTransaction","/web-client/reference/interfaces/plaintransaction","web-client/reference/interfaces/PlainTransaction",{"title":839,"path":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":334,"body":921,"description":1541,"extension":1542,"icon":1543,"layout":1544,"meta":1545,"navigation":1547,"path":335,"seo":1548,"stem":336,"__hash__":1549},"docs/protocol/node-sync/live-sync/block-live-sync.md",{"type":922,"value":923,"toc":1526},"minimark",[924,928,945,955,962,993,999,1006,1011,1031,1037,1147,1152,1208,1214,1221,1224,1238,1241,1247,1250,1270,1276,1279,1296,1302,1323,1329,1332,1398,1412,1416,1419,1445,1451,1465,1470,1473,1494,1499,1519,1522],[925,926,927],"p",{},"Block Live Sync is used by:",[929,930,931,939],"ul",{},[932,933,934,938],"li",{},[935,936,937],"strong",{},"History nodes"," – Download full block bodies (including transactions)",[932,940,941,944],{},[935,942,943],{},"Light and Pico nodes"," – Download block headers only",[925,946,947,948,954],{},"Full nodes do not use Block Live Sync. Instead, they transition to ",[935,949,950],{},[951,952,338],"a",{"href":953},"state-live-sync"," to synchronize both blocks and complete account state simultaneously.",[956,957,959],"h2",{"id":958},"key-characteristics",[935,960,961],{},"Key Characteristics",[929,963,964,970,976,982],{},[932,965,966,969],{},[935,967,968],{},"Real-Time Micro Block Synchronization",": Continuously follows the latest micro blocks after macro sync.",[932,971,972,975],{},[935,973,974],{},"Peer-Independent Processing",": The system processes each peer independently for block announcements and missing block detection.",[932,977,978,981],{},[935,979,980],{},"Flexible Download Modes",": Supports both full block bodies and header-only modes.",[932,983,984,987,988,992],{},[935,985,986],{},"Stream-Based",": Implements asynchronous processing via the ",[989,990,991],"code",{},"Stream"," trait.",[956,994,996],{"id":995},"how-it-works",[935,997,998],{},"How It Works",[925,1000,1001,1002,1005],{},"The ",[989,1003,1004],{},"BlockLiveSync"," manages real-time blockchain synchronization by processing incoming block announcements, buffering out-of-order blocks, and proactively requesting missing blocks from peers. It ensures the node maintains synchronization with the network's current state through continuous block processing.",[925,1007,1001,1008,1010],{},[989,1009,1004],{}," follows a reactive request pattern:",[929,1012,1013,1019,1025],{},[932,1014,1015,1018],{},[935,1016,1017],{},"Block Announcements"," → Process incoming blocks via gossipsub",[932,1020,1021,1024],{},[935,1022,1023],{},"RequestMissingBlocks"," → Request missing blocks when gaps are detected (see Network Messages)",[932,1026,1027,1030],{},[935,1028,1029],{},"Block Buffering"," → Buffer out-of-order blocks until predecessors arrive",[956,1032,1034],{"id":1033},"architecture-overview",[935,1035,1036],{},"Architecture Overview",[1038,1039,1044],"pre",{"className":1040,"code":1041,"language":1042,"meta":1043,"style":1043},"language-rust shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","pub type BlockLiveSync\u003CN> = LiveSyncer\u003CN, BlockQueue\u003CN>>;\n\npub struct LiveSyncer\u003CN: Network, Q: LiveSyncQueue\u003CN>> {\n    blockchain: BlockchainProxy,\n\n    network: Arc\u003CN>,\n\n    queue: Q,\n\n    /// Vector of pending push operations.\n    pending: VecDeque\u003CBoxFuture\u003C'static, Q::PushResult>>,\n\n    /// Cache for BLS public keys to avoid repetitive uncompressing.\n    bls_cache: Arc\u003CMutex\u003CBlsCache>>,\n\n    /// Channel used to communicate additional blocks to the queue.\n    /// We use this to wake up the queue and pass in new, unknown blocks\n    /// received in the consensus as part of the head requests.\n    block_tx: mpsc::Sender\u003CBlockAndSource\u003CN>>,\n}\n","rust","",[989,1045,1046,1053,1059,1064,1069,1073,1078,1082,1087,1091,1096,1101,1105,1110,1115,1119,1124,1129,1135,1141],{"__ignoreMap":1043},[1047,1048,1050],"span",{"class":1049,"line":12},"line",[1047,1051,1052],{},"pub type BlockLiveSync\u003CN> = LiveSyncer\u003CN, BlockQueue\u003CN>>;\n",[1047,1054,1055],{"class":1049,"line":27},[1047,1056,1058],{"emptyLinePlaceholder":1057},true,"\n",[1047,1060,1061],{"class":1049,"line":22},[1047,1062,1063],{},"pub struct LiveSyncer\u003CN: Network, Q: LiveSyncQueue\u003CN>> {\n",[1047,1065,1066],{"class":1049,"line":17},[1047,1067,1068],{},"    blockchain: BlockchainProxy,\n",[1047,1070,1071],{"class":1049,"line":88},[1047,1072,1058],{"emptyLinePlaceholder":1057},[1047,1074,1075],{"class":1049,"line":228},[1047,1076,1077],{},"    network: Arc\u003CN>,\n",[1047,1079,1080],{"class":1049,"line":223},[1047,1081,1058],{"emptyLinePlaceholder":1057},[1047,1083,1084],{"class":1049,"line":204},[1047,1085,1086],{},"    queue: Q,\n",[1047,1088,1089],{"class":1049,"line":194},[1047,1090,1058],{"emptyLinePlaceholder":1057},[1047,1092,1093],{"class":1049,"line":199},[1047,1094,1095],{},"    /// Vector of pending push operations.\n",[1047,1097,1098],{"class":1049,"line":213},[1047,1099,1100],{},"    pending: VecDeque\u003CBoxFuture\u003C'static, Q::PushResult>>,\n",[1047,1102,1103],{"class":1049,"line":179},[1047,1104,1058],{"emptyLinePlaceholder":1057},[1047,1106,1107],{"class":1049,"line":184},[1047,1108,1109],{},"    /// Cache for BLS public keys to avoid repetitive uncompressing.\n",[1047,1111,1112],{"class":1049,"line":189},[1047,1113,1114],{},"    bls_cache: Arc\u003CMutex\u003CBlsCache>>,\n",[1047,1116,1117],{"class":1049,"line":218},[1047,1118,1058],{"emptyLinePlaceholder":1057},[1047,1120,1121],{"class":1049,"line":238},[1047,1122,1123],{},"    /// Channel used to communicate additional blocks to the queue.\n",[1047,1125,1126],{"class":1049,"line":233},[1047,1127,1128],{},"    /// We use this to wake up the queue and pass in new, unknown blocks\n",[1047,1130,1132],{"class":1049,"line":1131},18,[1047,1133,1134],{},"    /// received in the consensus as part of the head requests.\n",[1047,1136,1138],{"class":1049,"line":1137},19,[1047,1139,1140],{},"    block_tx: mpsc::Sender\u003CBlockAndSource\u003CN>>,\n",[1047,1142,1144],{"class":1049,"line":1143},20,[1047,1145,1146],{},"}\n",[925,1148,1149],{},[935,1150,1151],{},"Key components:",[1153,1154,1155,1172],"table",{},[1156,1157,1158],"thead",{},[1159,1160,1161,1167],"tr",{},[1162,1163,1164],"th",{},[935,1165,1166],{},"Component",[1162,1168,1169],{},[935,1170,1171],{},"Purpose",[1173,1174,1175,1188,1198],"tbody",{},[1159,1176,1177,1183],{},[1178,1179,1180],"td",{},[989,1181,1182],{},"LiveSyncer",[1178,1184,1185,1186],{},"Main sync controller implementing ",[989,1187,991],{},[1159,1189,1190,1195],{},[1178,1191,1192],{},[989,1193,1194],{},"BlockQueue",[1178,1196,1197],{},"Manages block buffering, ordering, and gap detection",[1159,1199,1200,1205],{},[1178,1201,1202],{},[989,1203,1204],{},"BlockRequestComponent",[1178,1206,1207],{},"Handles network requests for missing blocks",[956,1209,1211],{"id":1210},"step-by-step-process",[935,1212,1213],{},"Step-by-Step Process",[1215,1216,1218],"h3",{"id":1217},"_1-block-reception",[935,1219,1220],{},"1. Block Reception",[925,1222,1223],{},"The node receives blocks from two sources:",[929,1225,1226,1232],{},[932,1227,1228,1231],{},[935,1229,1230],{},"Announced blocks",": Via gossipsub block announcements from peers",[932,1233,1234,1237],{},[935,1235,1236],{},"Requested blocks",": Responses to missing block requests",[925,1239,1240],{},"Each block is classified with its source for proper validation and peer management.",[1215,1242,1244],{"id":1243},"_2-block-classification",[935,1245,1246],{},"2. Block Classification",[925,1248,1249],{},"Each incoming block is classified by the queue as:",[929,1251,1252,1258,1264],{},[932,1253,1254,1257],{},[935,1255,1256],{},"Head"," – Parent known, block processed immediately",[932,1259,1260,1263],{},[935,1261,1262],{},"Buffered"," – Block ahead of current state, stored temporarily",[932,1265,1266,1269],{},[935,1267,1268],{},"Missing"," – Block cannot be processed due to gaps; predecessor requested",[1215,1271,1273],{"id":1272},"_3-missing-block-resolution",[935,1274,1275],{},"3. Missing Block Resolution",[925,1277,1278],{},"When the system detects chain gaps:",[929,1280,1281,1284,1290,1293],{},[932,1282,1283],{},"Generate block locators from current head to last macro block",[932,1285,1286,1287,1289],{},"Send ",[989,1288,1023],{}," with target hash and locators",[932,1291,1292],{},"Track pending requests to avoid duplicates",[932,1294,1295],{},"Once the gaps are filled, the node processes all buffered blocks in order",[1215,1297,1299],{"id":1298},"_4-blockchain-integration",[935,1300,1301],{},"4. Blockchain Integration",[929,1303,1304,1307,1317,1320],{},[932,1305,1306],{},"Validate block signatures and intrinsic properties",[932,1308,1309,1310,1313,1314],{},"Push accepted blocks to blockchain using ",[989,1311,1312],{},"push()"," or ",[989,1315,1316],{},"push_with_chunks()",[932,1318,1319],{},"Process buffered blocks that become applicable",[932,1321,1322],{},"Update BLS cache with new validator keys",[956,1324,1326],{"id":1325},"configuration-differences",[935,1327,1328],{},"Configuration Differences",[925,1330,1331],{},"The behavior of Block Live Sync depends on the QueueConfig:",[1038,1333,1335],{"className":1040,"code":1334,"language":1042,"meta":1043,"style":1043},"pub struct QueueConfig {\n    /// Buffer size limit\n    pub buffer_max: usize,\n\n    /// How many blocks ahead we will buffer.\n    pub window_ahead_max: u32,\n\n    /// How many blocks back into the past we tolerate without returning a peer as Outdated.\n    pub tolerate_past_max: u32,\n\n    /// Flag to indicate if blocks should carry a body.\n    pub include_body: bool,\n}\n",[989,1336,1337,1342,1347,1352,1356,1361,1366,1370,1375,1380,1384,1389,1394],{"__ignoreMap":1043},[1047,1338,1339],{"class":1049,"line":12},[1047,1340,1341],{},"pub struct QueueConfig {\n",[1047,1343,1344],{"class":1049,"line":27},[1047,1345,1346],{},"    /// Buffer size limit\n",[1047,1348,1349],{"class":1049,"line":22},[1047,1350,1351],{},"    pub buffer_max: usize,\n",[1047,1353,1354],{"class":1049,"line":17},[1047,1355,1058],{"emptyLinePlaceholder":1057},[1047,1357,1358],{"class":1049,"line":88},[1047,1359,1360],{},"    /// How many blocks ahead we will buffer.\n",[1047,1362,1363],{"class":1049,"line":228},[1047,1364,1365],{},"    pub window_ahead_max: u32,\n",[1047,1367,1368],{"class":1049,"line":223},[1047,1369,1058],{"emptyLinePlaceholder":1057},[1047,1371,1372],{"class":1049,"line":204},[1047,1373,1374],{},"    /// How many blocks back into the past we tolerate without returning a peer as Outdated.\n",[1047,1376,1377],{"class":1049,"line":194},[1047,1378,1379],{},"    pub tolerate_past_max: u32,\n",[1047,1381,1382],{"class":1049,"line":199},[1047,1383,1058],{"emptyLinePlaceholder":1057},[1047,1385,1386],{"class":1049,"line":213},[1047,1387,1388],{},"    /// Flag to indicate if blocks should carry a body.\n",[1047,1390,1391],{"class":1049,"line":179},[1047,1392,1393],{},"    pub include_body: bool,\n",[1047,1395,1396],{"class":1049,"line":184},[1047,1397,1146],{},[929,1399,1400,1406],{},[932,1401,1402,1405],{},[935,1403,1404],{},"History Nodes"," → Download full transaction data for archival purposes",[932,1407,1408,1411],{},[935,1409,1410],{},"Light/Pico Nodes"," → Download headers only for efficient operation",[956,1413,1415],{"id":1414},"event-processing","Event Processing",[925,1417,1418],{},"Block Live Sync emits structured events for different scenarios:",[929,1420,1421,1427,1433,1439],{},[932,1422,1423,1426],{},[989,1424,1425],{},"AcceptedAnnouncedBlock(hash)"," - Live block accepted",[932,1428,1429,1432],{},[989,1430,1431],{},"AcceptedBufferedBlock(hash, buffer_size)"," - Buffered block applied",[932,1434,1435,1438],{},[989,1436,1437],{},"ReceivedMissingBlocks(hashes)"," - Missing blocks successfully received",[932,1440,1441,1444],{},[989,1442,1443],{},"RejectedBlock(hash)"," - Block validation failed",[1215,1446,1448],{"id":1447},"peer-events",[935,1449,1450],{},"Peer Events",[929,1452,1453,1459],{},[932,1454,1455,1458],{},[989,1456,1457],{},"Behind(peer_id)"," - Peer is behind our blockchain state",[932,1460,1461,1464],{},[989,1462,1463],{},"Ahead(peer_id)"," - Peer is ahead of our blockchain state",[925,1466,1467],{},[935,1468,1469],{},"Peer Classification Logic:",[925,1471,1472],{},"Peers are classified based on the block height difference and tolerance configuration:",[929,1474,1475,1485],{},[932,1476,1477,1480,1481,1484],{},[935,1478,1479],{},"Behind",": Peer's announced block is more than ",[989,1482,1483],{},"tolerate_past_max"," blocks behind our current head",[932,1486,1487,1480,1490,1493],{},[935,1488,1489],{},"Ahead",[989,1491,1492],{},"window_ahead_max"," blocks ahead of our current head",[925,1495,1496],{},[935,1497,1498],{},"System Actions:",[929,1500,1501,1507,1513],{},[932,1502,1503,1506],{},[935,1504,1505],{},"Behind peers",": Excluded from missing block requests but remain connected for potential catch-up",[932,1508,1509,1512],{},[935,1510,1511],{},"Ahead peers",": May trigger missing block requests if the gap is bridgeable, otherwise marked for potential disconnection",[932,1514,1515,1518],{},[935,1516,1517],{},"Excessive drift",": Peers too far ahead or behind may be disconnected to maintain sync efficiency",[925,1520,1521],{},"This event-driven approach enables the consensus layer to track synchronization progress and make informed decisions about peer management and sync strategy.",[1523,1524,1525],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":1043,"searchDepth":27,"depth":27,"links":1527},[1528,1529,1530,1531,1537,1538],{"id":958,"depth":27,"text":961},{"id":995,"depth":27,"text":998},{"id":1033,"depth":27,"text":1036},{"id":1210,"depth":27,"text":1213,"children":1532},[1533,1534,1535,1536],{"id":1217,"depth":22,"text":1220},{"id":1243,"depth":22,"text":1246},{"id":1272,"depth":22,"text":1275},{"id":1298,"depth":22,"text":1301},{"id":1325,"depth":27,"text":1328},{"id":1414,"depth":27,"text":1415,"children":1539},[1540],{"id":1447,"depth":22,"text":1450},"Block Live Sync is the real-time block synchronization mechanism, used as the second phase of synchronization after macro sync completes. It enables nodes to follow the chain tip by processing micro blocks as they are produced. This mode targets nodes that do not require state synchronization.","md","i-tabler:cube",null,{"matter":1546},{"title":334,"description":1541},{"title":334,"order":12},{"title":334,"description":1541},"MSG4SyCvXvYH7m2JpIUmHShK9plhLyjYR-Qf9nj7QzM",[1551,1553],{"title":325,"path":326,"stem":327,"description":1552,"order":17,"children":-1},"Nimiq's consensus architecture centers on a two-phase synchronization model that separates epoch-level state synchronization from real-time block processing. This design enables efficient sync strategies tailored to different node capabilities while maintaining cryptographic security guarantees.",{"title":338,"path":339,"stem":340,"description":1554,"order":27,"children":-1},"State Live Sync is a comprehensive real-time synchronization mechanism designed exclusively for full blockchain instances. The State Live Sync simultaneously maintains both the latest blockchain state and complete account data through parallel block and state synchronization.",1773431218076]
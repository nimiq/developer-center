ainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":347,"body":921,"description":1486,"extension":1487,"icon":1488,"layout":1489,"meta":1490,"navigation":1492,"path":348,"seo":1493,"stem":349,"__hash__":1494},"docs/protocol/node-sync/macro-sync/history-macro-sync.md",{"type":922,"value":923,"toc":1468},"minimark",[924,929,969,973,981,986,1007,1014,1018,1094,1098,1103,1114,1118,1136,1140,1156,1160,1171,1175,1196,1199,1205,1208,1228,1232,1356,1360,1386,1390,1393,1398,1422,1427,1438,1441,1447,1461,1464],[925,926,928],"h2",{"id":927},"key-characteristics","Key Characteristics",[930,931,932,940,946,952,958],"ul",{},[933,934,935,939],"li",{},[936,937,938],"strong",{},"Peer-to-Peer Operation",": Each peer is handled independently with separate request queues",[933,941,942,945],{},[936,943,944],{},"Full History Reconstruction",": Retrieves and validates complete transaction history since genesis",[933,947,948,951],{},[936,949,950],{},"Full Blockchain Exclusive",": Compatible only with full blockchain instance",[933,953,954,957],{},[936,955,956],{},"Parallel Sync Clusters",": Organizes downloads into concurrent clusters for maximum efficiency",[933,959,960,963,964,968],{},[936,961,962],{},"Stream-Based",": Implements the ",[965,966,967],"code",{},"Stream"," trait for asynchronous event processing",[925,970,972],{"id":971},"how-it-works","How It Works",[974,975,976,977,980],"p",{},"The ",[965,978,979],{},"HistoryMacroSync"," manages blockchain synchronization through parallel cluster operations. It downloads complete macro block history with transaction data, organizing work into efficient parallel streams for maximum throughput.",[974,982,976,983,985],{},[965,984,979],{}," follows a cluster-based parallel request pattern:",[987,988,989,995,1001],"ol",{},[933,990,991,994],{},[936,992,993],{},"RequestMacroChain"," → Discover available election macro block chains and epoch information",[933,996,997,1000],{},[936,998,999],{},"RequestBatchSet"," → Download macro blocks with validation metadata and history proofs",[933,1002,1003,1006],{},[936,1004,1005],{},"RequestHistoryChunk"," → Retrieve complete transaction history chunks in parallel",[974,1008,1009,1010,1013],{},"The complete message specifications are documented in the ",[1011,1012,359],"a",{"href":360}," document.",[925,1015,1017],{"id":1016},"architecture-overview","Architecture Overview",[1019,1020,1025],"pre",{"className":1021,"code":1022,"language":1023,"meta":1024,"style":1024},"language-rust shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","pub struct HistoryMacroSync\u003CTNetwork: Network> {\n    pub(crate) blockchain: Arc\u003CRwLock\u003CBlockchain>>,\n    pub(crate) network: Arc\u003CTNetwork>,\n    pub(crate) network_event_rx: SubscribeEvents\u003CTNetwork::PeerId>,\n    pub(crate) peers: HashMap\u003CTNetwork::PeerId, usize>,\n    pub(crate) epoch_ids_stream:\n        FuturesUnordered\u003CBoxFuture\u003C'static, Option\u003CEpochIds\u003CTNetwork::PeerId>>>>,\n    pub(crate) epoch_clusters: VecDeque\u003CSyncCluster\u003CTNetwork>>,\n    pub(crate) checkpoint_clusters: VecDeque\u003CSyncCluster\u003CTNetwork>>,\n    pub(crate) active_cluster: Option\u003CSyncCluster\u003CTNetwork>>,\n    pub(crate) job_queue: VecDeque\u003CJob\u003CTNetwork>>,\n    pub(crate) waker: Option\u003CWaker>,\n}\n","rust","",[965,1026,1027,1034,1039,1044,1049,1054,1059,1064,1069,1074,1079,1084,1089],{"__ignoreMap":1024},[1028,1029,1031],"span",{"class":1030,"line":12},"line",[1028,1032,1033],{},"pub struct HistoryMacroSync\u003CTNetwork: Network> {\n",[1028,1035,1036],{"class":1030,"line":27},[1028,1037,1038],{},"    pub(crate) blockchain: Arc\u003CRwLock\u003CBlockchain>>,\n",[1028,1040,1041],{"class":1030,"line":22},[1028,1042,1043],{},"    pub(crate) network: Arc\u003CTNetwork>,\n",[1028,1045,1046],{"class":1030,"line":17},[1028,1047,1048],{},"    pub(crate) network_event_rx: SubscribeEvents\u003CTNetwork::PeerId>,\n",[1028,1050,1051],{"class":1030,"line":88},[1028,1052,1053],{},"    pub(crate) peers: HashMap\u003CTNetwork::PeerId, usize>,\n",[1028,1055,1056],{"class":1030,"line":228},[1028,1057,1058],{},"    pub(crate) epoch_ids_stream:\n",[1028,1060,1061],{"class":1030,"line":223},[1028,1062,1063],{},"        FuturesUnordered\u003CBoxFuture\u003C'static, Option\u003CEpochIds\u003CTNetwork::PeerId>>>>,\n",[1028,1065,1066],{"class":1030,"line":204},[1028,1067,1068],{},"    pub(crate) epoch_clusters: VecDeque\u003CSyncCluster\u003CTNetwork>>,\n",[1028,1070,1071],{"class":1030,"line":194},[1028,1072,1073],{},"    pub(crate) checkpoint_clusters: VecDeque\u003CSyncCluster\u003CTNetwork>>,\n",[1028,1075,1076],{"class":1030,"line":199},[1028,1077,1078],{},"    pub(crate) active_cluster: Option\u003CSyncCluster\u003CTNetwork>>,\n",[1028,1080,1081],{"class":1030,"line":213},[1028,1082,1083],{},"    pub(crate) job_queue: VecDeque\u003CJob\u003CTNetwork>>,\n",[1028,1085,1086],{"class":1030,"line":179},[1028,1087,1088],{},"    pub(crate) waker: Option\u003CWaker>,\n",[1028,1090,1091],{"class":1030,"line":184},[1028,1092,1093],{},"}\n",[925,1095,1097],{"id":1096},"step-by-step-process","Step-by-Step Process",[1099,1100,1102],"h3",{"id":1101},"_1-macro-chain-discovery","1. Macro Chain Discovery",[930,1104,1105,1111],{},[933,1106,1107,1108,1110],{},"The node sends ",[965,1109,993],{}," to peers to discover epoch IDs and identify checkpoint blocks",[933,1112,1113],{},"Block locators help find the highest common block between the node and its peers",[1099,1115,1117],{"id":1116},"_2-parallel-batch-set-downloads-per-cluster","2. Parallel Batch Set Downloads per Cluster",[930,1119,1120,1127,1133],{},[933,1121,1122,1123,1126],{},"The node creates one or more ",[965,1124,1125],{},"SyncCluster","s instances responsible for specific epoch ranges",[933,1128,1129,1130,1132],{},"It sends ",[965,1131,999],{}," messages to retrieve macro blocks along with metadata",[933,1134,1135],{},"Macro blocks are stored but not yet applied until their history is complete",[1099,1137,1139],{"id":1138},"_3-history-chunks-downloads","3. History Chunks Downloads",[930,1141,1142,1147,1153],{},[933,1143,1107,1144,1146],{},[965,1145,1005],{}," messages to download transaction history in manageable chunks",[933,1148,1149,1150,1152],{},"Each ",[965,1151,1125],{}," manages its own queue, allowing multiple history chunks to be retrieved in parallel",[933,1154,1155],{},"History chunks are verified using Merkle proofs against the macro block's history root",[1099,1157,1159],{"id":1158},"_4-block-application","4. Block Application",[930,1161,1162,1168],{},[933,1163,1164,1165],{},"Once all required history is downloaded and verified, the node applies macro blocks using ",[965,1166,1167],{},"push_history_sync()",[933,1169,1170],{},"This process updates the blockchain state without replaying every transaction",[1099,1172,1174],{"id":1173},"_5-sync-completion","5. Sync Completion",[930,1176,1177,1183,1186],{},[933,1178,1179,1180],{},"If the peer has no new epochs → Emit as ",[965,1181,1182],{},"Good",[933,1184,1185],{},"If missing epochs are found → Continue processing",[933,1187,1188,1189,1192,1193],{},"If validation fails → Emit as ",[965,1190,1191],{},"Outdated"," or ",[965,1194,1195],{},"Incompatible",[974,1197,1198],{},"This cycle continues until all clusters complete and peers are fully synchronized.",[925,1200,1202],{"id":1201},"concurrency-management",[936,1203,1204],{},"Concurrency Management",[974,1206,1207],{},"History Macro Sync uses multiple levels of parallelism to improve performance:",[930,1209,1210,1216,1222],{},[933,1211,1212,1215],{},[936,1213,1214],{},"Cluster-Level",": Multiple clusters process different epoch ranges simultaneously",[933,1217,1218,1221],{},[936,1219,1220],{},"Request-Level",": Batch set and history chunk requests proceed independently",[933,1223,1224,1227],{},[936,1225,1226],{},"Chunk-Level",": Multiple history chunks are downloaded in parallel per cluster",[1099,1229,1231],{"id":1230},"cluster-architecture","Cluster Architecture",[1019,1233,1235],{"className":1021,"code":1234,"language":1023,"meta":1024,"style":1024},"pub struct SyncCluster\u003CTNetwork: Network> {\n    pub id: usize,\n    pub epoch_ids: Vec\u003CBlake2bHash>,\n    pub first_epoch_number: usize,\n    pub first_block_number: usize,\n\n    // Both batch_set_queue and the history_queue share the same peers.\n    pub(crate) batch_set_queue:\n        SyncQueue\u003CTNetwork, Blake2bHash, BatchSetInfo, HistoryRequestError, BatchSetVerifyState>,\n    history_queue: SyncQueue\u003C\n        TNetwork,\n        HistoryChunkRequest,\n        (HistoryChunkRequest, HistoryTreeChunk),\n        HistoryRequestError,\n        (),\n    >,\n\n    pending_batch_sets: VecDeque\u003CPendingBatchSet>,\n    num_epochs_finished: usize,\n\n    blockchain: Arc\u003CRwLock\u003CBlockchain>>,\n    network: Arc\u003CTNetwork>,\n}\n",[965,1236,1237,1242,1247,1252,1257,1262,1268,1273,1278,1283,1288,1293,1298,1303,1308,1313,1318,1322,1328,1334,1339,1345,1351],{"__ignoreMap":1024},[1028,1238,1239],{"class":1030,"line":12},[1028,1240,1241],{},"pub struct SyncCluster\u003CTNetwork: Network> {\n",[1028,1243,1244],{"class":1030,"line":27},[1028,1245,1246],{},"    pub id: usize,\n",[1028,1248,1249],{"class":1030,"line":22},[1028,1250,1251],{},"    pub epoch_ids: Vec\u003CBlake2bHash>,\n",[1028,1253,1254],{"class":1030,"line":17},[1028,1255,1256],{},"    pub first_epoch_number: usize,\n",[1028,1258,1259],{"class":1030,"line":88},[1028,1260,1261],{},"    pub first_block_number: usize,\n",[1028,1263,1264],{"class":1030,"line":228},[1028,1265,1267],{"emptyLinePlaceholder":1266},true,"\n",[1028,1269,1270],{"class":1030,"line":223},[1028,1271,1272],{},"    // Both batch_set_queue and the history_queue share the same peers.\n",[1028,1274,1275],{"class":1030,"line":204},[1028,1276,1277],{},"    pub(crate) batch_set_queue:\n",[1028,1279,1280],{"class":1030,"line":194},[1028,1281,1282],{},"        SyncQueue\u003CTNetwork, Blake2bHash, BatchSetInfo, HistoryRequestError, BatchSetVerifyState>,\n",[1028,1284,1285],{"class":1030,"line":199},[1028,1286,1287],{},"    history_queue: SyncQueue\u003C\n",[1028,1289,1290],{"class":1030,"line":213},[1028,1291,1292],{},"        TNetwork,\n",[1028,1294,1295],{"class":1030,"line":179},[1028,1296,1297],{},"        HistoryChunkRequest,\n",[1028,1299,1300],{"class":1030,"line":184},[1028,1301,1302],{},"        (HistoryChunkRequest, HistoryTreeChunk),\n",[1028,1304,1305],{"class":1030,"line":189},[1028,1306,1307],{},"        HistoryRequestError,\n",[1028,1309,1310],{"class":1030,"line":218},[1028,1311,1312],{},"        (),\n",[1028,1314,1315],{"class":1030,"line":238},[1028,1316,1317],{},"    >,\n",[1028,1319,1320],{"class":1030,"line":233},[1028,1321,1267],{"emptyLinePlaceholder":1266},[1028,1323,1325],{"class":1030,"line":1324},18,[1028,1326,1327],{},"    pending_batch_sets: VecDeque\u003CPendingBatchSet>,\n",[1028,1329,1331],{"class":1030,"line":1330},19,[1028,1332,1333],{},"    num_epochs_finished: usize,\n",[1028,1335,1337],{"class":1030,"line":1336},20,[1028,1338,1267],{"emptyLinePlaceholder":1266},[1028,1340,1342],{"class":1030,"line":1341},21,[1028,1343,1344],{},"    blockchain: Arc\u003CRwLock\u003CBlockchain>>,\n",[1028,1346,1348],{"class":1030,"line":1347},22,[1028,1349,1350],{},"    network: Arc\u003CTNetwork>,\n",[1028,1352,1354],{"class":1030,"line":1353},23,[1028,1355,1093],{},[1099,1357,1359],{"id":1358},"parallel-processing-limits","Parallel Processing Limits",[930,1361,1362,1368,1374,1380],{},[933,1363,1364,1367],{},[936,1365,1366],{},"Batch Sets",": 5 concurrent downloads per cluster",[933,1369,1370,1373],{},[936,1371,1372],{},"History Chunks",": 12 concurrent downloads per cluster",[933,1375,1376,1379],{},[936,1377,1378],{},"Max Clusters",": 100 total active clusters",[933,1381,1382,1385],{},[936,1383,1384],{},"Job Queue",": 4 maximum queued completion jobs",[925,1387,1389],{"id":1388},"event-processing","Event Processing",[974,1391,1392],{},"History Macro Sync emits structured events for different peer synchronization scenarios:",[974,1394,1395],{},[936,1396,1397],{},"Sync Events:",[930,1399,1400,1406,1412],{},[933,1401,1402,1405],{},[965,1403,1404],{},"MacroSyncReturn::Good(peer_id)"," - Peer successfully synchronized, no new epochs available",[933,1407,1408,1411],{},[965,1409,1410],{},"MacroSyncReturn::Outdated(peer_id)"," - Peer validation failed or provided outdated information",[933,1413,1414,1417,1418],{},[965,1415,1416],{},"MacroSyncReturn::Incompatible(peer_id)"," - Peer does not provide required services for synchronization; ",[1419,1420,1421],"em",{},"Example: A full node cannot serve a history node because it does not store the full transaction history from genesis, making it incompatible for history sync requests",[974,1423,1424],{},[936,1425,1426],{},"Progress Events:",[930,1428,1429,1432,1435],{},[933,1430,1431],{},"Cluster completion notifications for parallel download tracking",[933,1433,1434],{},"Batch set download completion per epoch range",[933,1436,1437],{},"History chunk application progress within clusters",[974,1439,1440],{},"This event system enables the consensus layer to track synchronization progress across multiple peers and make informed decisions about when sufficient peers have achieved macro sync completion.",[925,1442,1444],{"id":1443},"transition-to-live-sync",[936,1445,1446],{},"Transition to Live Sync",[974,1448,1449,1450,1453,1454,1456,1457,1460],{},"When History Macro Sync emits ",[965,1451,1452],{},"MacroSyncReturn::Good"," for sufficient peers, the consensus layer initiates the transition to ",[936,1455,329],{},". The node transitions to ",[1011,1458,334],{"href":1459},"../live-sync/block-live-sync"," to follow new micro blocks in real time.",[974,1462,1463],{},"This two-phase approach (macro sync → live sync) ensures nodes can quickly reach consensus state then maintain real-time synchronization with minimal overhead.",[1465,1466,1467],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":1024,"searchDepth":27,"depth":27,"links":1469},[1470,1471,1472,1473,1480,1484,1485],{"id":927,"depth":27,"text":928},{"id":971,"depth":27,"text":972},{"id":1016,"depth":27,"text":1017},{"id":1096,"depth":27,"text":1097,"children":1474},[1475,1476,1477,1478,1479],{"id":1101,"depth":22,"text":1102},{"id":1116,"depth":22,"text":1117},{"id":1138,"depth":22,"text":1139},{"id":1158,"depth":22,"text":1159},{"id":1173,"depth":22,"text":1174},{"id":1201,"depth":27,"text":1204,"children":1481},[1482,1483],{"id":1230,"depth":22,"text":1231},{"id":1358,"depth":22,"text":1359},{"id":1388,"depth":27,"text":1389},{"id":1443,"depth":27,"text":1446},"History Macro Sync is a full history synchronization mechanism designed exclusively for history nodes. It downloads the complete blockchain transaction history from genesis. The History Macro Sync is required for nodes that need to serve historical queries or verify the full transaction history.","md","i-tabler:history",null,{"matter":1491},{"title":347,"description":1486},{"title":347,"order":12},{"title":347,"description":1486},"IQEDaRCPEpwu2IHMVOeE6zJTsgdet2sUFkj8vyEFhpc",[1496,1498],{"title":338,"path":339,"stem":340,"description":1497,"order":27,"children":-1},"State Live Sync is a comprehensive real-time synchronization mechanism designed exclusively for full blockchain instances. The State Live Sync simultaneously maintains both the latest blockchain state and complete account data through parallel block and state synchronization.",{"title":351,"path":352,"stem":353,"description":1499,"order":27,"children":-1},"Light Macro Sync is a robust, ZKP-based synchronization mechanism designed for secure blockchain state verification. It operates with both full and light blockchain instances and provides cryptographically verified synchronization by leveraging Zero-Knowledge Proofs (ZKPs) to verify the macro chain validity before application to the local blockchain.",1773431218183]
ath":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":355,"body":921,"description":1507,"extension":1508,"icon":1509,"layout":1510,"meta":1511,"navigation":1513,"path":356,"seo":1514,"stem":357,"__hash__":1515},"docs/protocol/node-sync/macro-sync/pico-macro-sync.md",{"type":922,"value":923,"toc":1490},"minimark",[924,929,969,973,981,986,1025,1032,1036,1208,1212,1217,1220,1224,1227,1243,1247,1250,1264,1268,1271,1295,1299,1302,1328,1332,1336,1339,1342,1349,1355,1369,1375,1399,1403,1406,1411,1441,1446,1465,1469,1483,1486],[925,926,928],"h2",{"id":927},"key-characteristics","Key Characteristics",[930,931,932,940,946,952,958],"ul",{},[933,934,935,939],"li",{},[936,937,938],"strong",{},"Peer-to-Peer Operation",": Each peer is handled independently with separate request queues",[933,941,942,945],{},[936,943,944],{},"Optimistic Approach",": Accepts blocks with minimal validation",[933,947,948,951],{},[936,949,950],{},"Minimal State",": Only tracks essential information needed for the sync process",[933,953,954,957],{},[936,955,956],{},"Fast Fallback",": Can quickly transition to Light Macro Sync when conflicts are detected",[933,959,960,963,964,968],{},[936,961,962],{},"Stream-Based",": Implements the ",[965,966,967],"code",{},"Stream"," trait for asynchronous event processing",[925,970,972],{"id":971},"how-it-works","How It Works",[974,975,976,977,980],"p",{},"The ",[965,978,979],{},"PicoMacroSync"," manages macro block synchronization for each peer individually using a two-step process optimized for speed and efficiency.",[974,982,976,983,985],{},[965,984,979],{}," follows a minimal request pattern:",[987,988,989,995,1001],"ol",{},[933,990,991,994],{},[936,992,993],{},"RequestHead"," → Request the peer's head which returns the peer's election hash and the peer's latest macro block hash",[933,996,997,1000],{},[936,998,999],{},"RequestBlock"," → Use those hashes to request the respective blocks and apply them to the blockchain",[933,1002,1003,1006,1009,1010,1013,1014,1016,1017,1020,1021,1024],{},[936,1004,1005],{},"Then either:",[1007,1008],"br",{},"3.1 ",[936,1011,1012],{},"First-time sync (at genesis block):"," The blocks are simply applied to the blockchain, or",[1007,1015],{},"3.2 ",[936,1018,1019],{},"Subsequent peer syncs:"," The node compares the peer's head hashes to what it already has. If they are equal, the peer is marked as ",[965,1022,1023],{},"Good",". If the hashes are different, there's a conflict and the node falls back to the regular macro sync mechanism.",[974,1026,1027,1028,1031],{},"The complete message specifications are documented in the ",[1029,1030,359],"a",{"href":360}," document.",[925,1033,1035],{"id":1034},"architecture-overview","Architecture Overview",[1037,1038,1040],"collapsible",{"title":1039},"Pico Macro Sync Struct (click to expand)",[1041,1042,1047],"pre",{"className":1043,"code":1044,"language":1045,"meta":1046,"style":1046},"language-rust shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","pub struct PicoMacroSync\u003CTNetwork: Network> {\n    /// The blockchain\n    pub(crate) blockchain: BlockchainProxy,\n    /// Reference to the network\n    pub(crate) network: Arc\u003CTNetwork>,\n    /// Stream for peer joined and peer left events\n    pub(crate) network_event_rx: SubscribeEvents\u003CTNetwork::PeerId>,\n    /// Used to track the macro requests on a per peer basis\n    pub(crate) peer_requests: HashMap\u003CTNetwork::PeerId, PeerMacroRequests>,\n    /// The stream for head requests\n    pub(crate) head_stream:\n        FuturesUnordered\u003CBoxFuture\u003C'static, Option\u003C(ResponseHead, TNetwork::PeerId)>>>,\n    /// Block requests\n    pub(crate) block_headers: FuturesUnordered\u003C\n        BoxFuture\u003C\n            'static,\n            (\n                Result\u003CResult\u003CBlock, BlockError>, RequestError>,\n                TNetwork::PeerId,\n            ),\n        >,\n    >,\n    /// Collection of peers we are currently pico macro syncing with\n    pub(crate) syncing_peers: HashSet\u003CTNetwork::PeerId>,\n    /// Reference to the ZKP proxy used to interact with the ZKP component\n    /// It is not used by the pico consensus itself, but we need the reference\n    /// as part of the fallback mechanism\n    pub(crate) zkp_component_proxy: ZKPComponentProxy\u003CTNetwork>,\n}\n","rust","",[965,1048,1049,1056,1061,1066,1071,1076,1081,1086,1091,1096,1101,1106,1111,1116,1121,1126,1131,1136,1142,1148,1154,1160,1166,1172,1178,1184,1190,1196,1202],{"__ignoreMap":1046},[1050,1051,1053],"span",{"class":1052,"line":12},"line",[1050,1054,1055],{},"pub struct PicoMacroSync\u003CTNetwork: Network> {\n",[1050,1057,1058],{"class":1052,"line":27},[1050,1059,1060],{},"    /// The blockchain\n",[1050,1062,1063],{"class":1052,"line":22},[1050,1064,1065],{},"    pub(crate) blockchain: BlockchainProxy,\n",[1050,1067,1068],{"class":1052,"line":17},[1050,1069,1070],{},"    /// Reference to the network\n",[1050,1072,1073],{"class":1052,"line":88},[1050,1074,1075],{},"    pub(crate) network: Arc\u003CTNetwork>,\n",[1050,1077,1078],{"class":1052,"line":228},[1050,1079,1080],{},"    /// Stream for peer joined and peer left events\n",[1050,1082,1083],{"class":1052,"line":223},[1050,1084,1085],{},"    pub(crate) network_event_rx: SubscribeEvents\u003CTNetwork::PeerId>,\n",[1050,1087,1088],{"class":1052,"line":204},[1050,1089,1090],{},"    /// Used to track the macro requests on a per peer basis\n",[1050,1092,1093],{"class":1052,"line":194},[1050,1094,1095],{},"    pub(crate) peer_requests: HashMap\u003CTNetwork::PeerId, PeerMacroRequests>,\n",[1050,1097,1098],{"class":1052,"line":199},[1050,1099,1100],{},"    /// The stream for head requests\n",[1050,1102,1103],{"class":1052,"line":213},[1050,1104,1105],{},"    pub(crate) head_stream:\n",[1050,1107,1108],{"class":1052,"line":179},[1050,1109,1110],{},"        FuturesUnordered\u003CBoxFuture\u003C'static, Option\u003C(ResponseHead, TNetwork::PeerId)>>>,\n",[1050,1112,1113],{"class":1052,"line":184},[1050,1114,1115],{},"    /// Block requests\n",[1050,1117,1118],{"class":1052,"line":189},[1050,1119,1120],{},"    pub(crate) block_headers: FuturesUnordered\u003C\n",[1050,1122,1123],{"class":1052,"line":218},[1050,1124,1125],{},"        BoxFuture\u003C\n",[1050,1127,1128],{"class":1052,"line":238},[1050,1129,1130],{},"            'static,\n",[1050,1132,1133],{"class":1052,"line":233},[1050,1134,1135],{},"            (\n",[1050,1137,1139],{"class":1052,"line":1138},18,[1050,1140,1141],{},"                Result\u003CResult\u003CBlock, BlockError>, RequestError>,\n",[1050,1143,1145],{"class":1052,"line":1144},19,[1050,1146,1147],{},"                TNetwork::PeerId,\n",[1050,1149,1151],{"class":1052,"line":1150},20,[1050,1152,1153],{},"            ),\n",[1050,1155,1157],{"class":1052,"line":1156},21,[1050,1158,1159],{},"        >,\n",[1050,1161,1163],{"class":1052,"line":1162},22,[1050,1164,1165],{},"    >,\n",[1050,1167,1169],{"class":1052,"line":1168},23,[1050,1170,1171],{},"    /// Collection of peers we are currently pico macro syncing with\n",[1050,1173,1175],{"class":1052,"line":1174},24,[1050,1176,1177],{},"    pub(crate) syncing_peers: HashSet\u003CTNetwork::PeerId>,\n",[1050,1179,1181],{"class":1052,"line":1180},25,[1050,1182,1183],{},"    /// Reference to the ZKP proxy used to interact with the ZKP component\n",[1050,1185,1187],{"class":1052,"line":1186},26,[1050,1188,1189],{},"    /// It is not used by the pico consensus itself, but we need the reference\n",[1050,1191,1193],{"class":1052,"line":1192},27,[1050,1194,1195],{},"    /// as part of the fallback mechanism\n",[1050,1197,1199],{"class":1052,"line":1198},28,[1050,1200,1201],{},"    pub(crate) zkp_component_proxy: ZKPComponentProxy\u003CTNetwork>,\n",[1050,1203,1205],{"class":1052,"line":1204},29,[1050,1206,1207],{},"}\n",[925,1209,1211],{"id":1210},"step-by-step-process","Step-by-Step Process",[1213,1214,1216],"h3",{"id":1215},"_1-head-request","1. Head Request",[974,1218,1219],{},"The node sends a RequestHead message to the peer to obtain its current macro and election block hashes. Then, it extracts the macro and election block hashes to determine the peer's macro state and guide the next request.",[1213,1221,1223],{"id":1222},"_2-state-comparison","2. State Comparison",[974,1225,1226],{},"Compare peer's head with local blockchain state:",[930,1228,1229,1237],{},[933,1230,1231,1234,1235],{},[936,1232,1233],{},"Match"," → Mark as ",[965,1236,1023],{},[933,1238,1239,1242],{},[936,1240,1241],{},"Different hashes"," → Continue to block requests",[1213,1244,1246],{"id":1245},"_3-targeted-block-requests","3. Targeted Block Requests",[974,1248,1249],{},"Request only the specific blocks needed:",[930,1251,1252,1258],{},[933,1253,1254,1257],{},[936,1255,1256],{},"Starting from genesis"," → Request peer's latest election block (trusted)",[933,1259,1260,1263],{},[936,1261,1262],{},"Have election block"," → Request only the next macro block in sequence",[1213,1265,1267],{"id":1266},"_4-optimistic-block-application","4. Optimistic Block Application",[974,1269,1270],{},"Apply blocks with simple validation rules:",[930,1272,1273,1279,1285],{},[933,1274,1275,1278],{},[936,1276,1277],{},"Election block",": Only accepted if local blockchain is at genesis",[933,1280,1281,1284],{},[936,1282,1283],{},"Macro block",": Only accepted if it is the immediate next epoch",[933,1286,1287,1290,1291,1294],{},[936,1288,1289],{},"Any other case",": Mark peer as ",[965,1292,1293],{},"Conflicting",", fall back to Light Macro Sync",[1213,1296,1298],{"id":1297},"_5-verify-completion","5. Verify Completion",[974,1300,1301],{},"Re-request the peer's head to check if more blocks are needed:",[930,1303,1304,1313,1319],{},[933,1305,1306,1309,1310,1312],{},[936,1307,1308],{},"Hashes match"," → Mark peer as ",[965,1311,1023],{},", sync complete",[933,1314,1315,1318],{},[936,1316,1317],{},"Still different"," → Repeat from step 3",[933,1320,1321,1324,1325],{},[936,1322,1323],{},"Validation failed"," → Fallback to ",[965,1326,1327],{},"LightMacroSync",[925,1329,1331],{"id":1330},"fallback-mechanism","Fallback Mechanism",[1213,1333,1335],{"id":1334},"conflicting-peer","Conflicting Peer",[974,1337,1338],{},"The Pico Macro Sync operates with minimal validation, accepting blocks optimistically to maximize speed.\nIt only accepts a new election block if the local chain is at genesis, since it cannot fully validate election blocks without full history.",[974,1340,1341],{},"If the node is not at genesis and receives an unknown election block, it cannot verify its validity.\nAccepting such a block could allow a malicious or faulty peer to inject an alternate chain or fork, risking the node’s security and consensus.",[974,1343,1344,1345,1348],{},"When a peer provides a block that cannot be optimistically and safely applied, the node marks the peer as ",[936,1346,1347],{},"conflicting",". This triggers a fallback to Light Macro Sync, which uses ZKPs to securely verify the chain state and resolve discrepancies.",[974,1350,1351,1352,1354],{},"Fallback to ",[965,1353,1327],{}," is triggered when:",[930,1356,1357,1360,1363,1366],{},[933,1358,1359],{},"Block validation fails during push operations",[933,1361,1362],{},"Peer provides blocks from wrong epoch",[933,1364,1365],{},"Network errors or malicious peer behavior detected",[933,1367,1368],{},"Peer state differs from current local state",[974,1370,976,1371,1374],{},[965,1372,1373],{},"EitherSyncer"," enum allows transitions between sync mechanisms:",[1041,1376,1378],{"className":1043,"code":1377,"language":1045,"meta":1046,"style":1046},"pub enum EitherSyncer\u003CN: Network> {\n    Normal(PicoMacroSync\u003CN>),       // Fast optimistic sync\n    Fallback(LightMacroSync\u003CN>),    // ZKP-based sync\n}\n",[965,1379,1380,1385,1390,1395],{"__ignoreMap":1046},[1050,1381,1382],{"class":1052,"line":12},[1050,1383,1384],{},"pub enum EitherSyncer\u003CN: Network> {\n",[1050,1386,1387],{"class":1052,"line":27},[1050,1388,1389],{},"    Normal(PicoMacroSync\u003CN>),       // Fast optimistic sync\n",[1050,1391,1392],{"class":1052,"line":22},[1050,1393,1394],{},"    Fallback(LightMacroSync\u003CN>),    // ZKP-based sync\n",[1050,1396,1397],{"class":1052,"line":17},[1050,1398,1207],{},[925,1400,1402],{"id":1401},"event-processing","Event Processing",[974,1404,1405],{},"Pico Macro Sync emits structured events for different synchronization scenarios:",[974,1407,1408],{},[936,1409,1410],{},"Sync Events:",[930,1412,1413,1419,1425,1435],{},[933,1414,1415,1418],{},[965,1416,1417],{},"MacroSyncReturn::Good(peer_id)"," - Peer successfully synchronized with optimistic validation",[933,1420,1421,1424],{},[965,1422,1423],{},"MacroSyncReturn::Outdated(peer_id)"," - Peer provided outdated blocks or failed basic validation",[933,1426,1427,1430,1431],{},[965,1428,1429],{},"MacroSyncReturn::Incompatible(peer_id)"," - Peer does not provide required services for synchronization; ",[1432,1433,1434],"em",{},"Example: A pico node cannot serve another pico node because it does not provide fully verifiable or authenticated data, making it incompatible for pico sync requests",[933,1436,1437,1440],{},[965,1438,1439],{},"MacroSyncReturn::Conflicting(peer_id)"," - Peer provided conflicting blocks, triggering fallback to Light Macro Sync",[974,1442,1443],{},[936,1444,1445],{},"Fallback Events:",[930,1447,1448,1451,1462],{},[933,1449,1450],{},"Fallback trigger detection when block validation fails",[933,1452,1453,1454,1456,1457,1459,1460],{},"Transition from ",[965,1455,979],{}," to ",[965,1458,1327],{}," via ",[965,1461,1373],{},[933,1463,1464],{},"Peer transfer to ZKP-based verification system",[925,1466,1468],{"id":1467},"transition-to-live-sync","Transition to Live Sync",[974,1470,1471,1472,1475,1476,1478,1479,1482],{},"When the Pico Macro Sync emits ",[965,1473,1474],{},"MacroSyncReturn::Good"," for sufficient peers, the consensus layer initiates the transition to ",[936,1477,329],{},". The node transitions to ",[1029,1480,334],{"href":1481},"../live-sync/block-live-sync"," to follow new micro blocks in real time.",[974,1484,1485],{},"This two-phase approach (macro sync → live sync) ensures nodes can quickly reach consensus state then maintain real-time synchronization with minimal overhead.",[1487,1488,1489],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":1046,"searchDepth":27,"depth":27,"links":1491},[1492,1493,1494,1495,1502,1505,1506],{"id":927,"depth":27,"text":928},{"id":971,"depth":27,"text":972},{"id":1034,"depth":27,"text":1035},{"id":1210,"depth":27,"text":1211,"children":1496},[1497,1498,1499,1500,1501],{"id":1215,"depth":22,"text":1216},{"id":1222,"depth":22,"text":1223},{"id":1245,"depth":22,"text":1246},{"id":1266,"depth":22,"text":1267},{"id":1297,"depth":22,"text":1298},{"id":1330,"depth":27,"text":1331,"children":1503},[1504],{"id":1334,"depth":22,"text":1335},{"id":1401,"depth":27,"text":1402},{"id":1467,"depth":27,"text":1468},"Pico Macro Sync is a lightweight sync mechanism designed for resource-constrained environments. It operates exclusively with light blockchain instances and provides fast initial synchronization by requesting only essential macro blocks (election and checkpoint blocks) from peers on a per-peer basis. Pico Macro Sync takes an optimistic approach by accepting macro blocks with minimal validation, then falling back to a more robust sync method if conflicts are detected.","md","i-tabler:minimize",null,{"matter":1512},{"title":355,"description":1507},{"title":355,"order":22},{"title":355,"description":1507},"RxWEKkDhL7n4AG1ZjMEePashffE49kGtcpOjCarQvPQ",[1517,1519],{"title":351,"path":352,"stem":353,"description":1518,"order":27,"children":-1},"Light Macro Sync is a robust, ZKP-based synchronization mechanism designed for secure blockchain state verification. It operates with both full and light blockchain instances and provides cryptographically verified synchronization by leveraging Zero-Knowledge Proofs (ZKPs) to verify the macro chain validity before application to the local blockchain.",{"title":359,"path":360,"stem":361,"description":1520,"order":228,"children":-1},"The consensus crate implements a comprehensive network protocol enabling nodes to synchronize with the blockchain and exchange data efficiently. Communication follows two primary patterns:",1773431218239]
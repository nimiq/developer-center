output","web-client/reference/interfaces/InitOutput",{"title":751,"path":752,"stem":753},"Interface: PlainAddStakeData","/web-client/reference/interfaces/plainaddstakedata","web-client/reference/interfaces/PlainAddStakeData",{"title":755,"path":756,"stem":757},"Interface: PlainBasicAccount","/web-client/reference/interfaces/plainbasicaccount","web-client/reference/interfaces/PlainBasicAccount",{"title":759,"path":760,"stem":761},"Interface: PlainBlockCommonFields","/web-client/reference/interfaces/plainblockcommonfields","web-client/reference/interfaces/PlainBlockCommonFields",{"title":763,"path":764,"stem":765},"Interface: PlainClientConfiguration","/web-client/reference/interfaces/plainclientconfiguration","web-client/reference/interfaces/PlainClientConfiguration",{"title":767,"path":768,"stem":769},"Interface: PlainCreateStakerData","/web-client/reference/interfaces/plaincreatestakerdata","web-client/reference/interfaces/PlainCreateStakerData",{"title":771,"path":772,"stem":773},"Interface: PlainCreateValidatorData","/web-client/reference/interfaces/plaincreatevalidatordata","web-client/reference/interfaces/PlainCreateValidatorData",{"title":775,"path":776,"stem":777},"Interface: PlainHtlcContract","/web-client/reference/interfaces/plainhtlccontract","web-client/reference/interfaces/PlainHtlcContract",{"title":779,"path":780,"stem":781},"Interface: PlainHtlcData","/web-client/reference/interfaces/plainhtlcdata","web-client/reference/interfaces/PlainHtlcData",{"title":783,"path":784,"stem":785},"Interface: PlainHtlcEarlyResolveProof","/web-client/reference/interfaces/plainhtlcearlyresolveproof","web-client/reference/interfaces/PlainHtlcEarlyResolveProof",{"title":787,"path":788,"stem":789},"Interface: PlainHtlcRegularTransferProof","/web-client/reference/interfaces/plainhtlcregulartransferproof","web-client/reference/interfaces/PlainHtlcRegularTransferProof",{"title":791,"path":792,"stem":793},"Interface: PlainHtlcTimeoutResolveProof","/web-client/reference/interfaces/plainhtlctimeoutresolveproof","web-client/reference/interfaces/PlainHtlcTimeoutResolveProof",{"title":795,"path":796,"stem":797},"Interface: PlainMacroBlock","/web-client/reference/interfaces/plainmacroblock","web-client/reference/interfaces/PlainMacroBlock",{"title":799,"path":800,"stem":801},"Interface: PlainMicroBlock","/web-client/reference/interfaces/plainmicroblock","web-client/reference/interfaces/PlainMicroBlock",{"title":803,"path":804,"stem":805},"Interface: PlainPeerInfo","/web-client/reference/interfaces/plainpeerinfo","web-client/reference/interfaces/PlainPeerInfo",{"title":807,"path":808,"stem":809},"Interface: PlainRawData","/web-client/reference/interfaces/plainrawdata","web-client/reference/interfaces/PlainRawData",{"title":811,"path":812,"stem":813},"Interface: PlainRawProof","/web-client/reference/interfaces/plainrawproof","web-client/reference/interfaces/PlainRawProof",{"title":815,"path":816,"stem":817},"Interface: PlainRetireStakeData","/web-client/reference/interfaces/plainretirestakedata","web-client/reference/interfaces/PlainRetireStakeData",{"title":819,"path":820,"stem":821},"Interface: PlainSetActiveStakeData","/web-client/reference/interfaces/plainsetactivestakedata","web-client/reference/interfaces/PlainSetActiveStakeData",{"title":823,"path":824,"stem":825},"Interface: PlainStaker","/web-client/reference/interfaces/plainstaker","web-client/reference/interfaces/PlainStaker",{"title":827,"path":828,"stem":829},"Interface: PlainStakingContract","/web-client/reference/interfaces/plainstakingcontract","web-client/reference/interfaces/PlainStakingContract",{"title":831,"path":832,"stem":833},"Interface: PlainStandardProof","/web-client/reference/interfaces/plainstandardproof","web-client/reference/interfaces/PlainStandardProof",{"title":835,"path":836,"stem":837},"Interface: PlainTransaction","/web-client/reference/interfaces/plaintransaction","web-client/reference/interfaces/PlainTransaction",{"title":839,"path":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":325,"body":921,"description":1449,"extension":1450,"icon":1451,"layout":1452,"meta":1453,"navigation":1455,"path":326,"seo":1456,"stem":327,"__hash__":1457},"docs/protocol/node-sync/architecture.md",{"type":922,"value":923,"toc":1435},"minimark",[924,929,937,960,966,980,991,995,1000,1014,1020,1034,1049,1053,1070,1085,1095,1099,1105,1111,1141,1146,1160,1170,1174,1184,1275,1284,1288,1297,1307,1313,1319,1323,1329,1335,1341,1345,1351,1357,1363,1371,1375,1386,1400,1405,1416,1421],[925,926,928],"h2",{"id":927},"two-phase-sync-architecture","Two-Phase Sync Architecture",[930,931,932,936],"p",{},[933,934,935],"strong",{},"Macro Sync Phase",": Establishes current network state efficiently by downloading and verifying macro blocks (epoch and checkpoint blocks). Different strategies optimize for various resource constraints:",[938,939,940,948,954],"ul",{},[941,942,943,947],"li",{},[944,945,347],"a",{"href":946},"macro-sync/history-macro-sync",": Complete historical verification for history nodes",[941,949,950,953],{},[944,951,351],{"href":952},"macro-sync/light-macro-sync",": ZKP-based verification for resource efficiency",[941,955,956,959],{},[944,957,355],{"href":958},"macro-sync/pico-macro-sync",": Trust-based approach with automatic security fallback",[930,961,962,965],{},[933,963,964],{},"Live Sync Phase",": Maintains real-time synchronization with ongoing micro block production:",[938,967,968,974],{},[941,969,970,973],{},[944,971,338],{"href":972},"live-sync/state-live-sync",": Complete state maintenance for full nodes",[941,975,976,979],{},[944,977,334],{"href":978},"live-sync/block-live-sync",": Header-only sync for light clients",[981,982,987],"pre",{"className":983,"code":985,"language":986},[984],"language-text","┌─────────────────┐     ┌─────────────────┐\n│   Application   │     │   Network       │\n│   Layer         │     │   Layer         │\n└─────────┬───────┘     └─────────┬───────┘\n          │                       │\n          v                       v\n┌─────────────────────────────────────────┐\n│           Consensus Component           │\n│  ┌─────────────┐  ┌─────────────────┐   │\n│  │ Consensus   │  │ ConsensusProxy  │   │\n│  │ (Core)      │  │ (Async Access)  │   │\n│  └─────────────┘  └─────────────────┘   │\n└─────────┬───────────────────────────────┘\n          │\n          v\n┌─────────────────────────────────────────┐\n│            Syncer Component             │\n│  ┌─────────────┐  ┌─────────────────┐   │\n│  │ Syncer      │  │ SyncerProxy     │   │\n│  │ (Strategy)  │  │ (Multi-variant) │   │\n│  └─────────────┘  └─────────────────┘   │\n└─────────┬───────────────────────────────┘\n          │\n          v\n┌─────────────────────────────────────────┐\n│          Sync Strategies                │\n│ ┌─────────┐ ┌──────────┐ ┌──────────┐   │\n│ │ History │ │  Light   │ │   Pico   │   │\n│ │ Macro   │ │  Macro   │ │  Macro   │   │\n│ └─────────┘ └──────────┘ └──────────┘   │\n│ ┌─────────┐ ┌──────────┐                │\n│ │ Block   │ │  State   │                │\n│ │ Live    │ │  Live    │                │\n│ └─────────┘ └──────────┘                │\n└─────────────────────────────────────────┘\n","text",[988,989,985],"code",{"__ignoreMap":990},"",[925,992,994],{"id":993},"system-components","System Components",[996,997,999],"h3",{"id":998},"coordination-layer","Coordination Layer",[930,1001,1002,1005,1006,1009,1010,1013],{},[933,1003,1004],{},"Consensus Component",": Acts as the central orchestrator, analyzing peer agreement and sync progress to determine network consensus state. Emits ",[988,1007,1008],{},"ConsensusEvent::Established"," and ",[988,1011,1012],{},"ConsensusEvent::Lost"," to coordinate system behavior.",[930,1015,1016,1019],{},[933,1017,1018],{},"Syncer Component",": Manages the macro sync → live sync lifecycle, selecting appropriate strategies based on node configuration and coordinating peer state transitions.",[930,1021,1022,1025,1026,1029,1030,1033],{},[933,1023,1024],{},"Proxy Architecture",": Both components use proxy patterns (",[988,1027,1028],{},"ConsensusProxy",", ",[988,1031,1032],{},"SyncerProxy",") to provide thread-safe async interfaces while maintaining clear separation between coordination logic and external access.",[930,1035,1036,1042,1043,1009,1045,1048],{},[933,1037,1038,1041],{},[988,1039,1040],{},"RemoteDataStore"," and Event Dispatcher",": Supporting components such as ",[988,1044,1040],{},[988,1046,1047],{},"RemoteEventDispatcher"," provide remote access to account, validator, and staker data, and enable address-based event subscriptions.",[996,1050,1052],{"id":1051},"strategy-implementation-layer","Strategy Implementation Layer",[930,1054,1055,1058,1059,1009,1062,1065,1066,1069],{},[933,1056,1057],{},"Sync Strategies",": Implement ",[988,1060,1061],{},"MacroSync",[988,1063,1064],{},"LiveSync"," traits to enable different verification approaches and resource optimization patterns. See ",[944,1067,363],{"href":1068},"traits-and-abstractions"," for detailed interface specifications.",[930,1071,1072,1075,1076,1029,1078,1080,1081,1084],{},[933,1073,1074],{},"Trait-Based Design",": The sync system is built around trait-based abstractions, such as ",[988,1077,1061],{},[988,1079,1064],{},", and ",[988,1082,1083],{},"LiveSyncQueue",". This approach allows for pluggable sync strategies, making it straightforward to extend or adapt the system for new node types or future requirements.",[930,1086,1087,1090,1091,1094],{},[933,1088,1089],{},"Queue Architecture",": The core of peer request coordination is the generic ",[988,1092,1093],{},"SyncQueue"," abstraction, which manages requests, retries, and peer rotation for all sync strategies.",[925,1096,1098],{"id":1097},"communication-architecture","Communication Architecture",[930,1100,1101,1104],{},[933,1102,1103],{},"Peer Classification Systems",": Different sync phases use specialized peer classification approaches.",[930,1106,1107,1110],{},[933,1108,1109],{},"Macro Sync Classification",":",[938,1112,1113,1119,1125,1135],{},[941,1114,1115,1118],{},[933,1116,1117],{},"Good",": Successfully synchronized to peer's macro state",[941,1120,1121,1124],{},[933,1122,1123],{},"Outdated",": Peer is behind local chain or provided outdated information",[941,1126,1127,1130,1131],{},[933,1128,1129],{},"Incompatible",": Peer does not provide required services for synchronization; ",[1132,1133,1134],"em",{},"Example: full node cannot serve a syncing history node",[941,1136,1137,1140],{},[933,1138,1139],{},"Conflicting",": Peer provided conflicting blockchain data (triggers fallback in Pico Sync)",[930,1142,1143,1110],{},[933,1144,1145],{},"Live Sync Classification",[938,1147,1148,1154],{},[941,1149,1150,1153],{},[933,1151,1152],{},"Behind",": Peer is too far behind our current blockchain position (exceeds tolerance threshold)",[941,1155,1156,1159],{},[933,1157,1158],{},"Ahead",": Peer is too far ahead of our current blockchain position (exceeds window limit)",[930,1161,1162,1165,1166,1169],{},[933,1163,1164],{},"Peer Management",": Peer management is handled by the ",[988,1167,1168],{},"PeerList"," abstraction, which tracks active peers, supports efficient peer rotation, and notifies components when peers join or leave the network.",[996,1171,1173],{"id":1172},"event-driven-coordination","Event-Driven Coordination",[930,1175,1176,1179,1180,1183],{},[933,1177,1178],{},"Structured Event System",": All major components communicate through asynchronous event streams, implementing the ",[988,1181,1182],{},"Stream"," trait. This enables the system to respond promptly to network changes, peer events, and sync progress:",[938,1185,1186,1199,1220,1230,1242,1266],{},[941,1187,1188,1191,1192,1029,1195,1198],{},[988,1189,1190],{},"ConsensusEvent",": System-wide consensus state changes (",[988,1193,1194],{},"Established",[988,1196,1197],{},"Lost",")",[941,1200,1201,1204,1205,1029,1208,1029,1211,1029,1214,1029,1217,1198],{},[988,1202,1203],{},"LiveSyncPushEvent",": Block processing outcomes (",[988,1206,1207],{},"AcceptedAnnouncedBlock",[988,1209,1210],{},"AcceptedBufferedBlock",[988,1212,1213],{},"ReceivedMissingBlocks",[988,1215,1216],{},"RejectedBlock",[988,1218,1219],{},"AcceptedChunks",[941,1221,1222,1225,1226,1029,1228,1198],{},[988,1223,1224],{},"LiveSyncPeerEvent",": Peer classification (",[988,1227,1152],{},[988,1229,1158],{},[941,1231,1232,1235,1236,1029,1239,1198],{},[988,1233,1234],{},"NetworkEvent",": Peer lifecycle management (",[988,1237,1238],{},"PeerJoined",[988,1240,1241],{},"PeerLeft",[941,1243,1244,1247,1248,1029,1251,1029,1254,1029,1257,1029,1260,1029,1263,1198],{},[988,1245,1246],{},"BlockchainEvent",": State transition coordination (",[988,1249,1250],{},"Extended",[988,1252,1253],{},"Rebranched",[988,1255,1256],{},"Finalized",[988,1258,1259],{},"EpochFinalized",[988,1261,1262],{},"HistoryAdopted",[988,1264,1265],{},"Stored",[941,1267,1268,1271,1272,1198],{},[988,1269,1270],{},"RemoteEvent",": Inter-peer notifications (",[988,1273,1274],{},"InterestingReceipts",[930,1276,1277,1280,1281,1283],{},[933,1278,1279],{},"Cross-Node Communication",": ",[988,1282,1047],{}," enables selective subscriptions between different node types, supporting efficient address-based notifications without full chain monitoring.",[925,1285,1287],{"id":1286},"performance","Performance",[930,1289,1290,1293,1294,1296],{},[933,1291,1292],{},"Async Stream Processing",": All major components implement ",[988,1295,1182],{}," trait for non-blocking, event-driven processing that maintains responsiveness under load.",[930,1298,1299,1302,1303,1306],{},[933,1300,1301],{},"Concurrency and Parallel Requests",":\nThe sync system frequently needs to communicate with multiple peers at once, such as when requesting blocks or proofs. To handle this efficiently, it uses Rust’s ",[988,1304,1305],{},"FuturesUnordered"," collection. This allows the system to manage many asynchronous tasks in parallel and process each result as soon as it becomes available, regardless of the order they were started. By doing so, the node can take advantage of the fastest responses, keep the synchronization pipeline full, and avoid delays caused by slower peers. This approach ensures high throughput and responsiveness during all phases of synchronization.",[930,1308,1309,1312],{},[933,1310,1311],{},"Parallel Request Management",": Multi-peer concurrent request coordination with automatic load balancing and failure recovery ensures optimal network utilization.",[930,1314,1315,1318],{},[933,1316,1317],{},"Resource Management",": Configurable buffer sizes and connection limits enable tuning for different deployment environments and resource constraints.",[925,1320,1322],{"id":1321},"security","Security",[930,1324,1325,1328],{},[933,1326,1327],{},"Cryptographic Verification",": History and full nodes perform complete cryptographic validation of all received data.",[930,1330,1331,1334],{},[933,1332,1333],{},"ZKP Security",": Full and light nodes achieve high security through zero-knowledge proof verification.",[930,1336,1337,1340],{},[933,1338,1339],{},"Trust-Based Operation",": Pico nodes use optimistic trust with automatic fallback to cryptographic verification when conflicts are detected.",[925,1342,1344],{"id":1343},"error-handling","Error Handling",[930,1346,1347,1350],{},[933,1348,1349],{},"Automatic Peer Rotation",": Network request failures trigger immediate peer failover with exponential backoff to prevent cascading failures.",[930,1352,1353,1356],{},[933,1354,1355],{},"Peer Banning",": Peers that provide invalid data or misbehave are subject to banning or disconnection. This mechanism protects the node from malicious actors and helps maintain the network's integrity and security.",[930,1358,1359,1362],{},[933,1360,1361],{},"State Recovery",": When errors occur pushing blocks or chunks, the system discards pending chunks and requests chunks again starting from the earliest missing key in the local accounts tree state.",[930,1364,1365,1370],{},[933,1366,1367],{},[988,1368,1369],{},"EitherSyncer",": This abstraction enables seamless runtime fallback between sync strategies, such as automatically switching from Pico Macro Sync to Light Macro Sync when conflicts are detected, without disrupting the overall sync process.",[925,1372,1374],{"id":1373},"consensus-establishment","Consensus Establishment",[930,1376,1377,1378,1381,1382,1385],{},"A node establishes consensus when it achieves both ",[933,1379,1380],{},"peer connectivity"," (minimum 3 peers) and ",[933,1383,1384],{},"state synchronization"," (complete required data), plus one of:",[938,1387,1388,1394],{},[941,1389,1390,1393],{},[933,1391,1392],{},"Network Activity",": Accepted 5+ block announcements extending the local chain",[941,1395,1396,1399],{},[933,1397,1398],{},"Peer Agreement",": Knowledge of head blocks from 2/3+ of connected peers",[930,1401,1402],{},[933,1403,1404],{},"Head Consensus:",[938,1406,1407,1410,1413],{},[941,1408,1409],{},"Poll multiple peers simultaneously for chain head",[941,1411,1412],{},"Require 2/3+ agreement on current blockchain state",[941,1414,1415],{},"Disconnect from peers with significantly different state",[930,1417,1418],{},[933,1419,1420],{},"Multi-Peer Verification and Proof Validation:",[938,1422,1423,1426,1429,1432],{},[941,1424,1425],{},"Request proofs from multiple peers for cross-validation",[941,1427,1428],{},"Compare responses to detect inconsistencies",[941,1430,1431],{},"Build consensus from majority agreement",[941,1433,1434],{},"Ban peers providing invalid data",{"title":990,"searchDepth":27,"depth":27,"links":1436},[1437,1438,1442,1445,1446,1447,1448],{"id":927,"depth":27,"text":928},{"id":993,"depth":27,"text":994,"children":1439},[1440,1441],{"id":998,"depth":22,"text":999},{"id":1051,"depth":22,"text":1052},{"id":1097,"depth":27,"text":1098,"children":1443},[1444],{"id":1172,"depth":22,"text":1173},{"id":1286,"depth":27,"text":1287},{"id":1321,"depth":27,"text":1322},{"id":1343,"depth":27,"text":1344},{"id":1373,"depth":27,"text":1374},"Nimiq's consensus architecture centers on a two-phase synchronization model that separates epoch-level state synchronization from real-time block processing. This design enables efficient sync strategies tailored to different node capabilities while maintaining cryptographic security guarantees.","md","i-tabler:building",null,{"matter":1454},{"title":325,"description":1449},{"title":325,"order":17},{"title":325,"description":1449},"GFCrSDlW2BxyL6tIhPklDKeKwBvt8RlMM8i63XPJ3tU",[1459,1461],{"title":319,"path":320,"stem":321,"description":1460,"order":12,"children":-1},"Design-level overview of how Nimiq nodes synchronize with the blockchain, across all node types and sync modes.",{"title":334,"path":335,"stem":336,"description":1462,"order":12,"children":-1},"Block Live Sync is the real-time block synchronization mechanism, used as the second phase of synchronization after macro sync completes. It enables nodes to follow the chain tip by processing micro blocks as they are produced. This mode targets nodes that do not require state synchronization.",1773431218007]
40,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":363,"body":921,"description":1449,"extension":1450,"icon":1451,"layout":1452,"meta":1453,"navigation":1455,"path":364,"seo":1456,"stem":365,"__hash__":1457},"docs/protocol/node-sync/traits-and-abstractions.md",{"type":922,"value":923,"toc":1428},"minimark",[924,954,958,963,969,979,985,1011,1016,1022,1026,1037,1042,1054,1058,1078,1082,1086,1092,1107,1114,1122,1128,1147,1154,1170,1177,1188,1193,1213,1217,1292,1296,1300,1314,1318,1324,1328,1336,1340,1358,1362,1377,1381,1392,1396],[925,926,927,938,946],"ul",{},[928,929,930,937],"li",{},[931,932,933],"strong",{},[934,935,936],"code",{},"MacroSync"," - Gets nodes caught up to current network state",[928,939,940,945],{},[931,941,942],{},[934,943,944],{},"LiveSync"," - Keeps nodes synchronized with real-time blocks",[928,947,948,953],{},[931,949,950],{},[934,951,952],{},"LiveSyncQueue"," - Defines how the system processes and applies blocks",[955,956,957],"p",{},"These traits enable the same consensus engine to work with different sync strategies while maintaining consistent coordination patterns.",[959,960,962],"h2",{"id":961},"core-trait-hierarchy","Core Trait Hierarchy",[964,965,967],"h3",{"id":966},"macrosync",[934,968,936],{},[955,970,971,972,974,975,978],{},"Different node types need fundamentally different approaches to reach current state. The Macro Sync gets nodes to the latest macro block state using different strategies based on node capabilities. It feeds into ",[934,973,944],{}," once the system establishes macro state. Coordinated by ",[934,976,977],{},"Syncer"," component.",[955,980,981,984],{},[931,982,983],{},"Key Implementations",":",[925,986,987,993,999,1005],{},[928,988,989,992],{},[934,990,991],{},"HistoryMacroSync"," - Downloads complete blockchain history for history nodes",[928,994,995,998],{},[934,996,997],{},"LightMacroSync"," - Uses ZKP verification for efficient sync",[928,1000,1001,1004],{},[934,1002,1003],{},"PicoMacroSync"," - Optimistic sync with automatic fallback to Light Macro Sync",[928,1006,1007,1010],{},[934,1008,1009],{},"EitherSyncer"," - Flexible wrapper enabling transition between Pico and Light macro sync strategies, automatically falling back to LightMacroSync when conflicts or limitations are detected during Pico Sync",[964,1012,1014],{"id":1013},"livesync",[934,1015,944],{},[955,1017,1018,1019,1021],{},"Once caught up with the macro state, all node types need to stay current, but with different data requirements. The ",[934,1020,944],{}," trait manages continuous block announcements and any missing blocks after the macro sync is complete.",[955,1023,1024,984],{},[931,1025,983],{},[925,1027,1028],{},[928,1029,1030,1033,1034,1036],{},[934,1031,1032],{},"LiveSyncer"," - Generic coordinator that delegates to queue strategies. It uses ",[934,1035,952],{}," implementations to define processing behavior.",[964,1038,1040],{"id":1039},"livesyncqueue",[934,1041,952],{},[955,1043,1044,1045,1047,1048,1050,1051,1053],{},"Defines how the system processes, buffers, and applies incoming blocks to the blockchain for different node requirements. The same block coordination logic works for all node types, but each node type needs to process and apply the data differently. The ",[934,1046,952],{}," trait allows the same ",[934,1049,1032],{}," coordinator to work with different processing strategies. The queue component plugs into ",[934,1052,1032],{}," to define processing behavior. Determines what data gets requested and how it is applied.",[955,1055,1056,984],{},[931,1057,983],{},[925,1059,1060,1066,1072],{},[928,1061,1062,1065],{},[934,1063,1064],{},"BlockQueue"," - Basic block processing for light/history nodes",[928,1067,1068,1071],{},[934,1069,1070],{},"StateQueue"," - State chunk coordination for full nodes",[928,1073,1074,1077],{},[934,1075,1076],{},"DiffQueue"," - Efficient incremental state updates",[959,1079,1081],{"id":1080},"component-map","Component Map",[964,1083,1085],{"id":1084},"components","Components",[955,1087,1088],{},[931,1089,1090],{},[934,1091,285],{},[925,1093,1094,1097],{},[928,1095,1096],{},"The central coordinator that determines when the system establishes consensus",[928,1098,1099,1100,1102,1103,1106],{},"Uses ",[934,1101,977],{}," for sync coordination, emits ",[934,1104,1105],{},"ConsensusEvent"," for system state",[955,1108,1109],{},[931,1110,1111],{},[934,1112,1113],{},"ConsensusProxy",[925,1115,1116,1119],{},[928,1117,1118],{},"Thread-safe, cloneable interface to consensus functionality",[928,1120,1121],{},"Provides transaction sending, state querying, and block resolution capabilities",[955,1123,1124],{},[931,1125,1126],{},[934,1127,977],{},[925,1129,1130,1133,1136],{},[928,1131,1132],{},"Manages macro sync → live sync transitions and peer compatibility",[928,1134,1135],{},"Bridges between different sync phases and handles peer state tracking",[928,1137,1138,1139,1142,1143,1146],{},"Contains ",[934,1140,1141],{},"macro_sync"," and ",[934,1144,1145],{},"live_sync"," trait objects for different strategies",[955,1148,1149],{},[931,1150,1151],{},[934,1152,1153],{},"SyncerProxy",[925,1155,1156,1159],{},[928,1157,1158],{},"Enum wrapper that abstracts over different node sync combinations: History/Full/Light/Pico",[928,1160,1161,1162,1164,1165,1142,1167,1169],{},"Each variant contains a ",[934,1163,977],{}," with specific ",[934,1166,936],{},[934,1168,944],{}," implementations",[955,1171,1172],{},[931,1173,1174],{},[934,1175,1176],{},"SyncQueue",[925,1178,1179,1182,1185],{},[928,1180,1181],{},"Generic request coordinator with peer rotation, retry logic, and response verification",[928,1183,1184],{},"Used by all sync implementations for network requests",[928,1186,1187],{},"Maintains ordered response processing with custom verification callbacks",[955,1189,1190],{},[931,1191,1192],{},"Request Components",[925,1194,1195,1201,1207],{},[928,1196,1197,1200],{},[934,1198,1199],{},"BlockRequestComponent"," - Missing block requests",[928,1202,1203,1206],{},[934,1204,1205],{},"ChunkRequestComponent"," - State chunk requests",[928,1208,1209,1212],{},[934,1210,1211],{},"DiffRequestComponent"," - Trie diff requests",[964,1214,1216],{"id":1215},"blockchain-services","Blockchain Services",[1218,1219,1220,1236],"table",{},[1221,1222,1223],"thead",{},[1224,1225,1226,1230,1233],"tr",{},[1227,1228,1229],"th",{},"Component",[1227,1231,1232],{},"Purpose",[1227,1234,1235],{},"Key Features",[1237,1238,1239,1253,1266,1279],"tbody",{},[1224,1240,1241,1247,1250],{},[1242,1243,1244],"td",{},[934,1245,1246],{},"RemoteDataStore\u003CN>",[1242,1248,1249],{},"Remote staking contract queries",[1242,1251,1252],{},"Merkle proof verification, validator/staker data",[1224,1254,1255,1260,1263],{},[1242,1256,1257],{},[934,1258,1259],{},"RemoteEventDispatcher\u003CN>",[1242,1261,1262],{},"Address-based event routing",[1242,1264,1265],{},"Client subscriptions, event notifications",[1224,1267,1268,1273,1276],{},[1242,1269,1270],{},[934,1271,1272],{},"BlsCache",[1242,1274,1275],{},"BLS key optimization",[1242,1277,1278],{},"LRU cache, validator voting key storage",[1224,1280,1281,1286,1289],{},[1242,1282,1283],{},[934,1284,1285],{},"HeadRequests\u003CN>",[1242,1287,1288],{},"Consensus peer analysis",[1242,1290,1291],{},"Head state tracking, missing block detection",[959,1293,1295],{"id":1294},"component-interactions","Component Interactions",[964,1297,1299],{"id":1298},"event-driven-communication","Event-Driven Communication",[955,1301,1302,1303,1142,1306,1309,1310,1313],{},"Components coordinate through event streams rather than direct method calls. The consensus system emits ",[934,1304,1305],{},"ConsensusEvent::Established",[934,1307,1308],{},"ConsensusEvent::Lost"," to signal state changes, while sync components emit ",[934,1311,1312],{},"LiveSyncEvent"," for block processing and peer status.",[964,1315,1317],{"id":1316},"request-coordination-pattern","Request Coordination Pattern",[955,1319,1320,1321,1323],{},"All sync strategies use ",[934,1322,1176],{}," for reliable peer coordination. When data is needed, sync implementations coordinate requests across multiple peers with automatic retry, peer rotation, and response verification.",[964,1325,1327],{"id":1326},"proxy-pattern-architecture","Proxy Pattern Architecture",[955,1329,1330,1332,1333,1335],{},[934,1331,1113],{}," provides thread-safe access via channels, ",[934,1334,1153],{}," is an enum wrapper for different sync strategies (History/Full/Light/Pico).",[964,1337,1339],{"id":1338},"stream-based-processing","Stream-Based Processing",[955,1341,1342,1343,1346,1347,1349,1350,1349,1352,1354,1355,1357],{},"Key coordination components implement ",[934,1344,1345],{},"Stream"," trait for async coordination: ",[934,1348,936],{},", ",[934,1351,944],{},[934,1353,952],{},", and ",[934,1356,1032],{},".",[964,1359,1361],{"id":1360},"generic-queue-architecture","Generic Queue Architecture",[955,1363,1364,1365,1367,1368,1349,1370,1354,1372,1374,1375,1357],{},"Same live sync coordination logic works with different processing strategies: ",[934,1366,952],{}," trait lets ",[934,1369,1064],{},[934,1371,1070],{},[934,1373,1076],{}," plug into ",[934,1376,1032],{},[964,1378,1380],{"id":1379},"fallback-mechanisms","Fallback Mechanisms",[955,1382,1383,1385,1386,1388,1389,1391],{},[934,1384,1009],{}," enables ",[934,1387,1003],{}," → ",[934,1390,997],{}," transitions when conflicts are detected.",[959,1393,1395],{"id":1394},"tldr","TL;DR",[1397,1398,1399,1406,1416,1423],"ol",{},[928,1400,1401,1405],{},[931,1402,1403],{},[934,1404,936],{}," → Node-specific strategies to reach the latest macro block",[928,1407,1408,1412,1413,1415],{},[931,1409,1410],{},[934,1411,944],{}," → Real-time synchronization phase: coordination with specialized queues (",[934,1414,952],{},") for different data requirements",[928,1417,1418,1422],{},[931,1419,1420],{},[934,1421,285],{}," → Analyzes peer agreement patterns and determines when the node has reached a consistent view of the network state",[928,1424,1425,1427],{},[931,1426,1192],{}," → Network request coordination: manages peer rotation, and retry logic for reliable data retrieval",{"title":1429,"searchDepth":27,"depth":27,"links":1430},"",[1431,1436,1440,1448],{"id":961,"depth":27,"text":962,"children":1432},[1433,1434,1435],{"id":966,"depth":22,"text":936},{"id":1013,"depth":22,"text":944},{"id":1039,"depth":22,"text":952},{"id":1080,"depth":27,"text":1081,"children":1437},[1438,1439],{"id":1084,"depth":22,"text":1085},{"id":1215,"depth":22,"text":1216},{"id":1294,"depth":27,"text":1295,"children":1441},[1442,1443,1444,1445,1446,1447],{"id":1298,"depth":22,"text":1299},{"id":1316,"depth":22,"text":1317},{"id":1326,"depth":22,"text":1327},{"id":1338,"depth":22,"text":1339},{"id":1360,"depth":22,"text":1361},{"id":1379,"depth":22,"text":1380},{"id":1394,"depth":27,"text":1395},"Three core traits form the foundation of the consensus system, creating a pluggable synchronization architecture:","md","i-tabler:code",null,{"matter":1454},{"title":363,"description":1449},{"title":363,"order":88},{"title":363,"description":1449},"xMFTky1oOoZ9T3h2muZaIETe7TAPFxB6ULu26GPhBz8",[1459,1461],{"title":359,"path":360,"stem":361,"description":1460,"order":228,"children":-1},"The consensus crate implements a comprehensive network protocol enabling nodes to synchronize with the blockchain and exchange data efficiently. Communication follows two primary patterns:",{"title":372,"path":373,"stem":374,"description":1462,"order":22,"children":-1},"The History Store is a component of the blockchain that is responsible for recording and maintaining all transactions that have occurred on the blockchain. This system ensures the integrity and traceability of transactions, serving as both a record-keeping and indexing tool. It allows easy retrieval of transactions, such as locating all transactions associated with a specific address.",1773431218297]
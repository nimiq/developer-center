,1321,1325,1333,1336,1343,1345,1348,1357,1360,1369,1371,1375,1383,1386,1389,1391,1394,1402],[971,972,973,977],"p",{},[974,975,783],"a",{"href":976},"../globals"," / PlainTransaction",[979,980,982],"h1",{"id":981},"interface-plaintransaction","Interface: PlainTransaction",[971,984,985],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:475",[971,987,988,989,993],{},"JSON-compatible and human-readable format of transactions. E.g. addresses are presented in their human-readable\nformat and address types and the network are represented as strings. Data and proof are serialized as an object\ndescribing their contents (not yet implemented, only the ",[990,991,992],"code",{},"{ raw: string }"," fallback is available).",[995,996,998],"h2",{"id":997},"extended-by","Extended by",[1000,1001,1002],"ul",{},[1003,1004,1005],"li",{},[974,1006,1007],{"href":884},[990,1008,884],{},[995,1010,1012],{"id":1011},"properties","Properties",[1014,1015,1016],"h3",{"id":1016},"data",[1018,1019,1020],"blockquote",{},[971,1021,1022,1025,1026],{},[1023,1024,1016],"strong",{},": ",[974,1027,1029],{"href":1028},"../type-aliases/PlainTransactionRecipientData",[990,1030,945],{},[971,1032,1033],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:540",[971,1035,1036,1037,1039],{},"The ",[990,1038,1016],{}," field of a transaction serves different purposes based on the transaction's recipient type.\nFor transactions to \"basic\" address types, this field can contain up to 64 bytes of unstructured data.\nFor transactions that create contracts or interact with the staking contract, the format of this field\nmust follow a fixed structure and defines the new contracts' properties or how the staking contract is\nchanged.",[1041,1042],"hr",{},[1014,1044,1045],{"id":1045},"fee",[1018,1047,1048],{},[971,1049,1050,1025,1052],{},[1023,1051,1045],{},[990,1053,1054],{},"number",[971,1056,1057],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:510",[971,1059,1060],{},"The transaction's fee in luna (NIM's smallest unit).",[1041,1062],{},[1014,1064,1066],{"id":1065},"feeperbyte","feePerByte",[1018,1068,1069],{},[971,1070,1071,1025,1073],{},[1023,1072,1066],{},[990,1074,1054],{},[971,1076,1077],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:514",[971,1079,1080],{},"The transaction's fee-per-byte in luna (NIM's smallest unit).",[1041,1082],{},[1014,1084,1085],{"id":1085},"flags",[1018,1087,1088],{},[971,1089,1090,1025,1092],{},[1023,1091,1085],{},[990,1093,1054],{},[971,1095,1096],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:527",[971,1098,1099,1100,1103,1104,1107],{},"Any flags that this transaction carries. ",[990,1101,1102],{},"0b1 = 1"," means it's a contract-creation transaction, ",[990,1105,1106],{},"0b10 = 2","\nmeans it's a signalling transaction with 0 value.",[1041,1109],{},[1014,1111,1112],{"id":1112},"format",[1018,1114,1115],{},[971,1116,1117,1025,1119,1122,1123],{},[1023,1118,1112],{},[990,1120,1121],{},"\"basic\""," | ",[990,1124,1125],{},"\"extended\"",[971,1127,1128],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:487",[971,1130,1131],{},"The transaction's format. Nimiq transactions can have one of two formats: \"basic\" and \"extended\".\nBasic transactions are simple value transfers between two regular address types and cannot contain\nany extra data. Basic transactions can be serialized to less bytes, so take up less place on the\nblockchain. Extended transactions on the other hand are all other transactions: contract creations\nand interactions, staking transactions, transactions with exta data, etc.",[1041,1133],{},[1014,1135,1136],{"id":1136},"network",[1018,1138,1139],{},[971,1140,1141,1025,1143],{},[1023,1142,1136],{},[990,1144,1145],{},"string",[971,1147,1148],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:522",[971,1150,1151],{},"The network name on which this transaction is valid.",[1041,1153],{},[1014,1155,1156],{"id":1156},"proof",[1018,1158,1159],{},[971,1160,1161,1025,1163],{},[1023,1162,1156],{},[974,1164,1166],{"href":1165},"../type-aliases/PlainTransactionProof",[990,1167,941],{},[971,1169,1170],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:546",[971,1172,1036,1173,1175],{},[990,1174,1156],{}," field contains the signature of the eligible signer. The proof field's structure depends on\nthe transaction's sender type. For transactions from contracts it can also contain additional structured\ndata before the signature.",[1041,1177],{},[1014,1179,1180],{"id":1180},"recipient",[1018,1182,1183],{},[971,1184,1185,1025,1187],{},[1023,1186,1180],{},[990,1188,1145],{},[971,1190,1191],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:500",[971,1193,1194],{},"The transaction's recipient address in human-readable IBAN format.",[1041,1196],{},[1014,1198,1200],{"id":1199},"recipienttype","recipientType",[1018,1202,1203],{},[971,1204,1205,1025,1207,1122,1209,1122,1212,1122,1215],{},[1023,1206,1200],{},[990,1208,1121],{},[990,1210,1211],{},"\"vesting\"",[990,1213,1214],{},"\"htlc\"",[990,1216,1217],{},"\"staking\"",[971,1219,1220],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:505",[971,1222,1223],{},"The account type of the transaction's recipient. \"basic\" are regular private-key controlled accounts,\n\"vesting\" and \"htlc\" are contracts, and \"staking\" is the staking contract.",[1041,1225],{},[1014,1227,1228],{"id":1228},"sender",[1018,1230,1231],{},[971,1232,1233,1025,1235],{},[1023,1234,1228],{},[990,1236,1145],{},[971,1238,1239],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:491",[971,1241,1242],{},"The transaction's sender address in human-readable IBAN format.",[1041,1244],{},[1014,1246,1248],{"id":1247},"senderdata","senderData?",[1018,1250,1251],{},[971,1252,1253,1256,1257,1025,1260],{},[990,1254,1255],{},"optional"," ",[1023,1258,1259],{},"senderData",[974,1261,1263],{"href":1262},"../type-aliases/PlainTransactionSenderData",[990,1264,949],{},[971,1266,1267],{},"Defined in: @nimiq/core/types/wasm/web.d.ts:532",[971,1269,1036,1270,1273],{},[990,1271,1272],{},"sender_data"," field serves a purpose based on the 
s/plaintransaction","web-client/reference/interfaces/PlainTransaction",{"title":839,"path":840,"stem":841},"Interface: PlainTransactionDetails","/web-client/reference/interfaces/plaintransactiondetails","web-client/reference/interfaces/PlainTransactionDetails",{"title":843,"path":844,"stem":845},"Interface: PlainTransactionReceipt","/web-client/reference/interfaces/plaintransactionreceipt","web-client/reference/interfaces/PlainTransactionReceipt",{"title":847,"path":848,"stem":849},"Interface: PlainUpdateStakerData","/web-client/reference/interfaces/plainupdatestakerdata","web-client/reference/interfaces/PlainUpdateStakerData",{"title":851,"path":852,"stem":853},"Interface: PlainUpdateValidatorData","/web-client/reference/interfaces/plainupdatevalidatordata","web-client/reference/interfaces/PlainUpdateValidatorData",{"title":855,"path":856,"stem":857},"Interface: PlainValidator","/web-client/reference/interfaces/plainvalidator","web-client/reference/interfaces/PlainValidator",{"title":859,"path":860,"stem":861},"Interface: PlainValidatorData","/web-client/reference/interfaces/plainvalidatordata","web-client/reference/interfaces/PlainValidatorData",{"title":863,"path":864,"stem":865},"Interface: PlainVestingContract","/web-client/reference/interfaces/plainvestingcontract","web-client/reference/interfaces/PlainVestingContract",{"title":867,"path":868,"stem":869},"Interface: PlainVestingData","/web-client/reference/interfaces/plainvestingdata","web-client/reference/interfaces/PlainVestingData",{"title":871,"path":872,"stem":873,"children":874,"page":101},"Type Aliases","/web-client/reference/type-aliases","web-client/reference/type-aliases",[875,879,883,887,891,895,899,903,907,911],{"title":876,"path":877,"stem":878},"Type Alias: ConsensusState","/web-client/reference/type-aliases/consensusstate","web-client/reference/type-aliases/ConsensusState",{"title":880,"path":881,"stem":882},"Type Alias: InitInput","/web-client/reference/type-aliases/initinput","web-client/reference/type-aliases/InitInput",{"title":884,"path":885,"stem":886},"Type Alias: PlainAccount","/web-client/reference/type-aliases/plainaccount","web-client/reference/type-aliases/PlainAccount",{"title":888,"path":889,"stem":890},"Type Alias: PlainBlock","/web-client/reference/type-aliases/plainblock","web-client/reference/type-aliases/PlainBlock",{"title":892,"path":893,"stem":894},"Type Alias: PlainService","/web-client/reference/type-aliases/plainservice","web-client/reference/type-aliases/PlainService",{"title":896,"path":897,"stem":898},"Type Alias: PlainTransactionProof","/web-client/reference/type-aliases/plaintransactionproof","web-client/reference/type-aliases/PlainTransactionProof",{"title":900,"path":901,"stem":902},"Type Alias: PlainTransactionRecipientData","/web-client/reference/type-aliases/plaintransactionrecipientdata","web-client/reference/type-aliases/PlainTransactionRecipientData",{"title":904,"path":905,"stem":906},"Type Alias: PlainTransactionSenderData","/web-client/reference/type-aliases/plaintransactionsenderdata","web-client/reference/type-aliases/PlainTransactionSenderData",{"title":908,"path":909,"stem":910},"Type Alias: SyncInitInput","/web-client/reference/type-aliases/syncinitinput","web-client/reference/type-aliases/SyncInitInput",{"title":912,"path":913,"stem":914},"Type Alias: TransactionState","/web-client/reference/type-aliases/transactionstate","web-client/reference/type-aliases/TransactionState",{"title":916,"path":917,"stem":918,"order":17},"Web Client vs RPC","/web-client/web-client-vs-rpc","web-client/web-client-vs-rpc",{"id":920,"title":49,"body":921,"description":1367,"extension":1368,"icon":1369,"layout":1369,"meta":1370,"navigation":1372,"path":50,"seo":1373,"stem":51,"__hash__":1374},"docs/archive/validator-activation.md",{"type":922,"value":923,"toc":1357},"minimark",[924,929,942,951,1017,1024,1029,1088,1094,1097,1168,1174,1177,1199,1212,1218,1232,1235,1268,1275,1281,1284,1332,1337,1341,1353],[925,926,928],"h2",{"id":927},"validator-activation-tool","Validator Activation Tool",[930,931,932,933,937,938,941],"p",{},"This guide covers ",[934,935,936],"strong",{},"Phase 3: Validator Activation",", which starts on ",[934,939,940],{},"November 19th",". The Validator Activation Tool facilitates the transition from the PoW chain to the PoS chain. We recommend running the tool before the activation window begins to allow time for database synchronization, as this process can take some time.",[930,943,944,945,950],{},"The tool will also automatically send online transactions every hour, signaling which validators are ready for the transition. Team Nimiq will fund all registered validator addresses with 100 Lunas before the activation window to cover these transactions. For more detailed information, click ",[946,947,949],"a",{"href":948},"../migration/migration-technical-details#activation-phase","here",".",[952,953,954,976],"table",{},[955,956,957],"thead",{},[958,959,960,966,971],"tr",{},[961,962,963],"th",{},[934,964,965],{},"Phase",[961,967,968],{},[934,969,970],{},"Start Date",[961,972,973],{},[934,974,975],{},"End Date",[977,978,979,991,1002],"tbody",{},[958,980,981,985,988],{},[982,983,984],"td",{},"Validator Registration",[982,986,987],{},"12th September",[982,989,990],{},"6th October",[958,992,993,996,999],{},[982,994,995],{},"Pre-Stake Phase",[982,997,998],{},"7th October",[982,1000,1001],{},"10th November",[958,1003,1004,1009,1014],{},[982,1005,1006],{},[934,1007,1008],{},"Validator Activation",[982,1010,1011],{},[934,1012,1013],{},"19th November",[982,1015,1016],{},"-",[930,1018,1019,1020,1023],{},"The steps outlined in this guide are only applicable for the ",[934,1021,1022],{},"Validator Activation Phase",". However, you can prepare by following these steps before that date.",[1025,1026,1028],"h3",{"id":1027},"prerequisites","Prerequisites",[1030,1031,1032,1042,1076],"ul",{},[1033,1034,1035,1037,1038],"li",{},[934,1036,984],{},": You must have already ",[946,1039,1041],{"href":1040},"validator-registration","registered as a validator",[1033,1043,1044,1047,1048,1054,1055],{},[934,1045,1046],{},"PoW Full Node",": You need access to a fully synchronized Nimiq PoW full node with RPC access enabled. If you are not already running a full node, follow the instructions in the ",[946,1049,1053],{"href":1050,"rel":1051},"https://github.com/nimiq/core-js",[1052],"nofollow","core-js repository"," to set it up and sync with the main network\n",[1030,1056,1057,1060,1069],{},[1033,1058,1059],{},"If you are running a PoW client, ensure it is fully synced and configured properly",[1033,1061,1062,1063,1068],{},"Use this ",[946,1064,1067],{"href":1065,"rel":1066},"https://github.com/nimiq/core-js/blob/master/clients/nodejs/sample.conf",[1052],"sample configuration file"," to enable RPC access on your PoW client",[1033,1070,1071,1072,1075],{},"During this phase, you will need to run both the PoW and PoS clients. Ensure they are configured to run on ",[934,1073,1074],{},"different RPC ports"," to avoid conflicts if you are running both clients on the same machine. Alternatively, running them on separate servers is also possible.",[1033,1077,1078,1081,1082,1087],{},[934,1079,1080],{},"PoS Blockchain Repository",": Clone the ",[946,1083,1086],{"href":1084,"rel":1085},"https://github.com/nimiq/core-rs-albatross?tab=readme-ov-file#installation",[1052],"PoS blockchain repository"," following the installation instructions",[1025,1089,1091],{"id":1090},"step-1-add-validator-data-into-the-configuration-file",[934,1092,1093],{},"Step 1: Add Validator Data into the Configuration File",[930,1095,1096],{},"Once your PoS client is set up, follow these steps:",[1098,1099,1100,1132,1139,1162],"ol",{},[1033,1101,1102,1103,1107,1108],{},"Check if the ",[1104,1105,1106],"code",{},"$HOME/.nimiq"," folder exists:\n",[1098,1109,1110,1117],{},[1033,1111,1112,1113,1116],{},"If it exists, open the configuration file in ",[1104,1114,1115],{},"$HOME/.nimiq/client.toml"," and locate the dedicated section for validators at the end",[1033,1118,1119,1120,1122,1123,1126,1127],{},"If it doesn’t exist, create the ",[1104,1121,1106],{}," folder and inside, create a ",[1104,1124,1125],{},"client.toml"," file based on this ",[946,1128,1131],{"href":1129,"rel":1130},"https://github.com/nimiq/core-rs-albatross/blob/albatross/lib/src/config/config_file/client.example.toml",[1052],"example",[1033,1133,1134,1135,1138],{},"Paste your ",[934,1136,1137],{},"validator data"," into the validator section (public key, signing key, voting key)",[1033,1140,1141,1142,1145,1146,1149,1150,1153,1154,1157,1158,1161],{},"Set the ",[934,1143,1144],{},"network"," is set to ",[1104,1147,1148],{},"main-albatross"," and the ",[1104,1151,1152],{},"sync_mode"," to ",[1104,1155,1156],{},"full"," or ",[1104,1159,1160],{},"history",". Only full or history nodes are eligible to become validators",[1033,1163,1164,1165,1167],{},"Review and adjust all the other sections of ",[1104,1166,1125],{}," and ensure that the parameters are configured according to your specific setup (paths, keys, and any optional features you want to enable). Adjust these settings as needed to fit your node's configuration",[1025,1169,1171],{"id":1170},"step-2-download-the-pow-chain-database-snapshot-optional",[934,1172,1173],{},"Step 2: Download the PoW Chain Database Snapshot (Optional)",[930,1175,1176],{},"If your PoW client is not synced or you’re setting it up from scratch, you can download a database snapshot to accelerate the synchronization process. This snapshot is particularly useful before running the Activation Tool, as it eliminates the need to sync the entire PoW chain from scratch. After downloading the snapshot, only a small portion of the chain needs to be synced, allowing your node to reach consensus more quickly:",[1030,1178,1179,1189],{},[1033,1180,1181,1184,1185],{},[934,1182,1183],{},"IPFS",": Download the full PoW chain snapshot ",[946,1186,949],{"href":1187,"rel":1188},"https://ipfs.nimiq.io/ipfs/QmRKvFVpTdXagvgZG5cF9qdz13x9DkZhUvwXAS5YMaqTfu?filename=pow-main-full-consensus.zip",[1052],[1033,1190,1191,1194,1195],{},[934,1192,1193],{},"Torrent",": Alternatively, download the snapshot via Torrent ",[946,1196,949],{"href":1197,"rel":1198},"https://repo.nimiq.com/torrents/nimiq-pow-main-full-consensus.torrent",[1052],[930,1200,1201,1202,1206,1207,1211],{},"After downloading the snapshot, extract the file and place the database in the directory from where you are running your PoW client configuration. Once in place, follow steps ",[946,1203,1205],{"href":1204},"#step-3-prepare-the-pow-client-for-the-transition","3"," and ",[946,1208,1210],{"href":1209},"#step-4-run-the-activation-tool","4",". After your node reaches consensus, continue with the Activation Tool to complete the process.",[1025,1213,1215],{"id":1214},"step-3-prepare-the-pow-client-for-the-transition",[934,1216,1217],{},"Step 3: Prepare the PoW Client for the Transition",[930,1219,1220,1221,1224,1225,950],{},"Ensure the ",[934,1222,1223],{},"PoW client is running with RPC enabled"," on a distinct port from the PoS client, as the following command both clients are running in the same machine. Configure the PoW client’s RPC settings in its configuration file by adding your validator address and key pair. Refer to ",[946,1226,1229],{"href":1227,"rel":1228},"https://github.com/nimiq/core-js/blob/master/clients/nodejs/sample.conf#L163",[1052],[934,1230,1231],{},"this example",[930,1233,1234],{},"Run the following command to start the PoW client:",[1236,1237,1242],"pre",{"className":1238,"code":1239,"language":1240,"meta":1241,"style":1241},"language-bash shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","    node clients/nodejs/index.js --dumb --network=main --rpc=8648 --wallet-seed=private_keypublic_key\n","bash","",[1104,1243,1244],{"__ignoreMap":1241},[1245,1246,1248,1252,1256,1259,1262,1265],"span",{"class":1247,"line":12},"line",[1245,1249,1251],{"class":1250},"sBMFI","    node",[1245,1253,1255],{"class":1254},"sfazB"," clients/nodejs/index.js",[1245,1257,1258],{"class":1254}," --dumb",[1245,1260,1261],{"class":1254}," --network=main",[1245,1263,1264],{"class":1254}," --rpc=8648",[1245,1266,1267],{"class":1254}," --wallet-seed=private_keypublic_key\n",[930,1269,1270,1271,1274],{},"The ",[1104,1272,1273],{},"private_keypublic_key"," is the concatenation of your private key and public key in that order. It's necessary because the activation tool will use these keys to send and sign transactions on behalf of your validator, signaling readiness.",[1025,1276,1278],{"id":1277},"step-4-run-the-activation-tool",[934,1279,1280],{},"Step 4: Run the Activation Tool",[930,1282,1283],{},"Once your PoW client is synced and in consensus, you are ready to run the Validator Activation Tool. This tool establishes a connection with the PoW chain via RPC and sets your validator ready for the PoS transition.",[1098,1285,1286,1305],{},[1033,1287,1288,1289,1293,1294,1296,1297],{},"Compile the PoS Client\nEnsure your PoS client is ",[946,1290,1292],{"href":1291},"#step-1-add-validator-data-into-the-configuration-file","properly configured"," in the ",[1104,1295,1125],{}," file, and your validator data is correctly set, and compile the PoS client:",[1236,1298,1303],{"className":1299,"code":1301,"language":1302},[1300],"language-text","cargo build --release\n","text",[1104,1304,1301],{"__ignoreMap":1241},[1033,1306,1307,1310,1311,1317,1320,1321,1324,1325,1328,1329],{},[934,1308,1309],{},"Run the Activation Tool"," using the following command in the PoS client directory:",[1236,1312,1315],{"className":1313,"code":1314,"language":1302},[1300],"cargo run --release --bin nimiq-pow-migration -- --url \"pow-rpc\" --config client.toml\n",[1104,1316,1314],{"__ignoreMap":1241},[1318,1319],"br",{},"Where ",[1104,1322,1323],{},"pow-rpc"," is the ",[934,1326,1327],{},"PoW client RPC url",". For example: ",[1104,1330,1331],{},"http://127.0.0.1:8648",[930,1333,1334,1335,950],{},"The tool will monitor validator readiness by tracking readiness transactions sent by all the registered validators within 24 hour activation windows. Once 80% of the total stake has signaled readiness, the activation tool will automatically start the PoS client. Read more about the activation process ",[946,1336,949],{"href":948},[1025,1338,1340],{"id":1339},"pos-activation","PoS Activation",[930,1342,1343,1344,1347,1348,1352],{},"On ",[934,1345,1346],{},"November 19",", the network will initiate the transition from PoW to PoS. Once 80% of the total stake signals their readiness, PoS chain starts with the ",[946,1349,1351],{"href":1350},"../migration/migration-technical-details","candidate block"," as the genesis block. The transition block will be generated, and validators will officially start securing the PoS network. Ensure your validator is ready and synced before this date to avoid delays.",[1354,1355,1356],"style",{},"html pre.shiki code .sBMFI, html code.shiki .sBMFI{--shiki-light:#E2931D;--shiki-default:#FFCB6B;--shiki-dark:#FFCB6B}html pre.shiki code .sfazB, html code.shiki .sfazB{--shiki-light:#91B859;--shiki-default:#C3E88D;--shiki-dark:#C3E88D}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":1241,"searchDepth":27,"depth":27,"links":1358},[1359],{"id":927,"depth":27,"text":928,"children":1360},[1361,1362,1363,1364,1365,1366],{"id":1027,"depth":22,"text":1028},{"id":1090,"depth":22,"text":1093},{"id":1170,"depth":22,"text":1173},{"id":1214,"depth":22,"text":1217},{"id":1277,"depth":22,"text":1280},{"id":1339,"depth":22,"text":1340},"This guide is part of the Nimiq PoW to PoS migration process and is intended for users who have already registered as validators during the Validator Registration Phase by October 6th, 2024. If you missed the registration deadline, you can still participate in the activation as an observer by following this guide.","md",null,{"matter":1371},{"title":49,"description":1367},true,{"title":49,"description":1367},"Rc6VxQrsSlGnEO6EOkTLqHiMuUV0DdgeGJNHsuOPWWk",[1376,1378],{"title":45,"path":46,"stem":47,"description":1377,"children":-1},"Our migration guides are designed for users who want to actively participate in the transition process. This specific guide is for those who want to run the migration process without becoming validators (if you want to become one of the first validators from the start of the PoS chain, please refer to this guide). It is suitable for:",{"title":53,"path":54,"stem":55,"description":1379,"children":-1},"This document guides users through the registration process to become one of the first validators on the Nimiq PoS chain. It is part of the overall documentation for the transition from PoW to PoS. For more technical details on the migration, see Migration Technical Details.",1773431213792]